# Duplicats macOS / iCloud / sync : ces fichiers apparaissent quand un editeur
# ou Finder fait une copie automatique (espace + chiffre devant l'extension).
# Ex : "og-card 2.tsx", "page (1).tsx". Ils polluent le repo et provoquent des
# warnings au build (Next.js scanne TOUS les fichiers .ts/.tsx).
* [0-9].ts
* [0-9].tsx
* [0-9].js
* [0-9].jsx
* [0-9].mjs
* [0-9].cjs
* [0-9].md
* [0-9].mdx
* [0-9].yml
* [0-9].yaml
* [0-9].json
* [0-9].sh
* [0-9].py
* \([0-9]\).ts
* \([0-9]\).tsx
* \([0-9]\).js
* \([0-9]\).jsx
* \([0-9]\).md
* \([0-9]\).mdx

# build outputs additionnels
/dist/
.cache/

# Runtime cache cyber-meteo (regenere a la demande)
.meteo-cache/

# TTS premium cache : MP3 generes par `npm run tts:build` (regenerable depuis
# le manifest, ~50-100 Mo). Le manifest.json EST commit pour la prod.
data/tts-cache/**/*.mp3
data/tts-cache/[0-9a-f][0-9a-f]/

# Ancien cache Piper (avant bascule Voxtral mai 2026) -- a supprimer si encore present
.tts-cache/

# node_modules dans workspaces nested
**/node_modules

# Cle privee Ed25519 pour licences (jamais commit)
humanix-license-keypair.json
*.private.pem

# TTS cache : MP3 generes par `npm run tts:build` (regenerable depuis le
# manifest, ~80-100 Mo). Le manifest.json EST commit pour la prod (texte
# ~30 Ko, source de verite des hashes). Les MP3 eux-memes sont gitignored.
data/tts-cache/**/*.mp3
data/tts-cache/[0-9a-f][0-9a-f]/

# Ancien cache Piper (avant bascule Voxtral mai 2026)
.tts-cache/

.claude/

# =============================================================================
# Open Core - contenu commercial prive (cf. docs/OPEN_CORE.md)
# -----------------------------------------------------------------------------
# Ces fichiers sont l'asset commercial principal de Humanix Cybersecurity :
# 159 modules MDX + 5500 lignes de catalogues/seeds. Ils doivent rester dans
# le repo prive `humanix-content-pro` et NE PAS apparaitre dans le repo public.
#
# DECOMMENTER ce bloc AVANT le passage public du repo (planifie 26 mai 2026).
# Cf. docs/OPEN_CORE.md section "Workflow operateur" pour la procedure de
# migration complete (cp -r + git rm --cached + submodule).
#
# Le code est prepare pour un fallback gracieux : si ces fichiers sont absents,
# l'app bascule automatiquement sur les saisons demo CC BY-SA livrees en OSS
# (cf. content/saisons-demo/ + prisma/catalog-saisons-demo.ts).
# =============================================================================
/content/saisons
/prisma/catalog-saisons.ts
/lib/library-seed.ts
/lib/marketplace-seed.ts
/lib/anecdotes/seed-data.ts

# Doc de travail interne : script de RV intuitem (jetable apres usage).
/docs/CISO_ASSISTANT_DEMO.md

# Dump local du schema OpenAPI de l'instance CISO Assistant.
# Utilise pour auditer le client contre le contrat reel - NE PAS commit
# (varie selon l'instance, peut contenir des UUIDs internes du client).
/connectors/ciso-assistant-schema/
.git.bak.*/

