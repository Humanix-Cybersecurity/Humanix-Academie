// HumaniX Academy - Schema BDD V0.5
// Multi-tenant logique : tout est filtre par tenantId

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// TENANT
// Multi-etablissements : un Tenant peut avoir un parent (groupe / siege).
// Le tenant racine = le contrat commercial. Les enfants = sites / agences /
// BU / etablissements. La facturation reste au niveau du tenant racine,
// le reporting est consolide.
// =====================================================
model Tenant {
  id                    String    @id @default(cuid())
  name                  String
  slug                  String    @unique
  // Plan effectif du tenant (cf. lib/plans.ts pour les valeurs valides :
  // starter, pro, enterprise — depuis pivot 4 paliers mai 2026).
  // Default "starter" (forever-free <=5 sieges) — plan le plus restrictif
  // qui ne necessite ni paiement ni provisionnement special.
  // Anciennes valeurs (decouverte/solo/essentielle/premium/trial) sont
  // gracieusement normalisees par lib/plans.ts::normalizePlan().
  plan                  String    @default("starter")
  // Multi-etablissements : un tenant peut avoir un parent (groupe / siege)
  parentTenantId        String?
  // Type d'etablissement libre (ex : "siege", "agence", "site", "boutique")
  // Affiche dans le breadcrumb / dashboard. null pour les tenants racine.
  establishmentType     String?
  // ----------------------------------------------------
  // BILLING (provider-agnostique : Payplug FR par defaut, possible Stripe)
  // ----------------------------------------------------
  // Identifie le prestataire de paiement actif pour ce tenant.
  // Valeurs : "payplug", "stripe", null (pas encore d'abonnement payant).
  paymentProvider       String?
  // Identifiants opaques chez le prestataire. Le format depend du provider
  // (Payplug : "cus_xxx", Stripe : "cus_xxx", interchangeables coté schema).
  paymentCustomerId     String?   @unique
  paymentSubscriptionId String?   @unique
  // Statut normalise : active, past_due, canceled, incomplete, unpaid.
  // ("trialing" est un statut legacy retire en mai 2026 mais encore tolere
  // par le state machine pour les anciens tenants — cf. lib/subscription-state.ts).
  // Source de verite = webhook du provider. Synchro a chaque event subscription.
  subscriptionStatus    String?
  // Fin de la periode de facturation courante (renouvellement automatique
  // OU coupure du service si subscriptionStatus=canceled).
  currentPeriodEnd      DateTime?
  // Numero de seats facturees (relevant pour Solo/Essentielle/Pro qui ont
  // un plafond). Null si plan flat-fee ou plan gratuit.
  seatCount             Int?
  // Champ legacy : date de fin de l'essai gratuit. Plus jamais ecrit depuis
  // le retrait de l'essai gratuit (mai 2026, vente directe). Conserve dans
  // le schema le temps de purger les anciennes valeurs en BDD via la
  // migration ; sera retire dans une migration future.
  trialEndsAt           DateTime?

  // ----------------------------------------------------
  // RGPD - Retention configurable des donnees
  // ----------------------------------------------------
  // Nombre de jours apres lesquels les donnees personnelles sont purgees /
  // anonymisees (RGPD art. 5.1.e - limitation de conservation). null =
  // pas de purge automatique (ancien comportement, opt-in).
  // Range valide en UI : 30-3650 (10 ans).
  //
  // Concretement, le cron /api/cron/data-retention-purge :
  //   - DELETE Event > seuil
  //   - DELETE AuditLog > seuil sauf actions critiques (cf. lib/data-retention.ts)
  //   - ANONYMIZE User inactif > seuil (email/name/IP vides, ID conserve
  //     pour integrite FK Progress / Event)
  //
  // Cf. lib/data-retention.ts pour la logique + dry-run.
  dataRetentionDays      Int?
  // Dernier passage de la purge automatique (info UI + heuristique cron).
  dataRetentionLastRunAt DateTime?

  // ----------------------------------------------------
  // SUSPENSION / DESACTIVATION (mai 2026)
  // ----------------------------------------------------
  // Geree par le SUPERADMIN depuis /superadmin/tenants/[id].
  // Un tenant desactive :
  //   - Refuse les nouveaux logins (cf. lib/auth.ts callbacks.signIn)
  //   - Garde ses donnees en BDD (pas une suppression)
  //   - Est filtre par defaut sur /superadmin/tenants (toggle "voir
  //     desactives" pour les afficher)
  // Defaut true (les tenants existants restent actifs apres migration).
  isActive       Boolean   @default(true)
  disabledAt     DateTime?
  // Email du SUPERADMIN qui a desactive (audit + UX "qui contacter").
  disabledBy     String?
  // Texte libre court (motif RGPD : conserve pour traçabilite).
  disabledReason String?

  // ----------------------------------------------------
  // AUTOMATIONS DE REMEDIATION (mai 2026)
  // ----------------------------------------------------
  // Flags opt-in (defaut false) configurables sur /admin/automations.
  // Declenches automatiquement quand un user clique sur un phishing
  // simule, en plus du mini-module flash auto-assigne. Permettent au
  // RSSI de monter le niveau de remediation sans intervention manuelle.
  //
  // autoForce2FAAfterPhishingClick : marque User.mfaForced=true si
  //   l'user n'a pas encore de 2FA. Au prochain login, il devra
  //   configurer le 2FA pour pouvoir continuer.
  // autoRevokeSessionAfterPhishingClick : supprime toutes les Session
  //   actives du user (deconnexion forcee de tous les devices). Au
  //   prochain acces, il devra se reconnecter (et configurer 2FA si
  //   le flag precedent est aussi activé).
  autoForce2FAAfterPhishingClick      Boolean  @default(false)
  autoRevokeSessionAfterPhishingClick Boolean  @default(false)
  createdAt                           DateTime @default(now())
  updatedAt                           DateTime @updatedAt

  parent   Tenant?  @relation("TenantHierarchy", fields: [parentTenantId], references: [id], onDelete: SetNull)
  children Tenant[] @relation("TenantHierarchy")

  users                 User[]
  saisons               Saison[]                  @relation("TenantSaisons")
  progress              Progress[]
  events                Event[]
  saisonConfigs         TenantSaisonConfig[]
  smtpConfig            TenantSmtpConfig?
  challenges            TeamChallenge[]
  apiKeys               ApiKey[]
  phishingCampaigns     PhishingCampaign[]
  notificationLogs      NotificationLog[]
  marketplaceInstalls   MarketplaceInstallation[]
  webhooks              TenantWebhook[]
  familyInvites         FamilyInvite[]
  transferRequests      TenantTransferRequest[]   @relation("TransferRequestTenant")
  impersonationSessions ImpersonationSession[]    @relation("ImpersonationAdminTenant")
  incidents             IncidentResponse[]
  riskScoreSnapshots    RiskScoreSnapshot[]
  cyberEventInstances   CyberEventInstance[]
  samlConfig            TenantSamlConfig?
  cisoConnection        CisoAssistantConnection?
  cisoSyncRuns          CisoAssistantSyncRun[]
  investigationResults  InvestigationResult[]
  // Memberships : users externes qui ont un role admin dans ce tenant
  // sans en etre membre natif (cf. TenantMembership). Cas typique : un
  // SUPERADMIN Humanix qui gere plusieurs tenants clients.
  memberships           TenantMembership[]

  @@index([parentTenantId])
}

// =====================================================
// TENANT SAML CONFIG - SSO SAML 2.0 par tenant (mai 2026)
// =====================================================
// Configuration SAML SP cote Humanix pour permettre aux grandes
// entreprises avec ADFS / Okta SAML / Azure AD SAML legacy de se
// federer.
//
// IMPLEMENTATION : 3 strategies disponibles (cf. /integrations/sso-saml) :
//   1. SAML-Jackson sidecar (recommande, OSS, traduit SAML -> OIDC)
//   2. Bridge Keycloak (le tenant deploie un Keycloak qui federe SAML
//      upstream et expose OIDC a Humanix)
//   3. Implementation native (a venir, requires @node-saml/node-saml)
//
// Cette table prepare la config a saisir cote admin /admin/sso-saml.
// L'activation runtime depend de l'installation cote infra de la voie
// choisie. L'admin telecharge les SP metadata pour les uploader chez
// son IdP.
// =====================================================
model TenantSamlConfig {
  id               String    @id @default(cuid())
  tenantId         String    @unique
  // Nom amical pour l'admin ("ADFS interne", "Okta production")
  label            String
  // SP Entity ID = identifiant unique de NOTRE service cote IdP.
  // Defaut : https://humanix-academie.fr/api/auth/saml/<tenantSlug>/metadata
  spEntityId       String
  // IdP-side : recus de l'admin du tenant qui les copie depuis son IdP
  idpEntityId      String
  idpSsoUrl        String    @db.Text // URL de redirect SSO de l'IdP
  idpCertificate   String    @db.Text // Cert X509 public (PEM) de l'IdP, pour valider signature
  // Mapping des attributs SAML -> champs User Humanix (JSON config)
  // Ex: { "email": "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress" }
  attributeMapping Json      @default("{}")
  isActive         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastTestedAt     DateTime?
  lastTestStatus   String? // "ok" | "error: ..."

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// =====================================================
// RISK SCORE SNAPSHOT - photo quotidienne du score de risque agrege
// du tenant. Permet le graphe d'evolution 90j sur le dashboard RSSI.
// Ecrit chaque jour par le cron /api/cron/risk-snapshot. Idempotent
// via @@unique([tenantId, day]) : si on re-run le cron le meme jour,
// on update la ligne existante.
// =====================================================
model RiskScoreSnapshot {
  id          String   @id @default(cuid())
  tenantId    String
  // Date du snapshot, normalisee a 00:00 UTC pour grouper par jour.
  // (On utilise pas DateTime.now() direct pour eviter d'avoir 2 lignes
  // dans la meme journee si le cron est rejoue manuellement.)
  day         DateTime
  // Population : nb de users actifs (LEARNER + MANAGER) au moment du snapshot.
  // Sert au denominateur pour les pourcentages affiches plus tard.
  userCount   Int
  // Distribution du riskScore (0-100) : moyenne + percentiles pour avoir
  // la dispersion (pas juste la moyenne qui peut masquer un gros ecart).
  avgScore    Float
  p10Score    Int // 10% des users sont en dessous : "queue de gauche"
  p50Score    Int // mediane (= "user typique")
  p90Score    Int // 10% des users au-dessus : "best in class"
  // Combien d'users en zone rouge (< 40) : visible dans la card "users
  // vulnerables" du dashboard sans avoir a tout recalculer.
  atRiskCount Int
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, day])
  @@index([tenantId, day])
}

// =====================================================
// BILLING - audit trail des events du prestataire de paiement
// Enregistre chaque webhook recu pour traçabilite (debug + RGPD).
// Les events sont aussi appliques au Tenant en parallele (statut, period
// end, seats), mais cette table garde l'historique brut.
// Provider-agnostique (payplug, stripe, ...).
// =====================================================
model BillingEvent {
  id                String   @id @default(cuid())
  // Identifie le prestataire de paiement (payplug, stripe, ...).
  provider          String   @default("payplug")
  // Hash unique d'idempotence pour eviter de traiter 2 fois le meme webhook
  // (le provider peut renvoyer le meme event plusieurs fois). Format
  // dependant du provider (Payplug : payment ID + status, Stripe : event.id).
  providerEventId   String   @unique
  type              String // ex: subscription.updated, payment.paid
  // Le tenant cible (peut etre null si on ne reconnait pas encore le customer
  // au moment du webhook, par ex. checkout completed orphelin)
  tenantId          String?
  // Snapshot du payload brut pour debug. Limite a 64 KB par Prisma.
  payload           Json
  // Resultat du traitement : "applied", "ignored", "error"
  status            String   @default("applied")
  errorMessage      String?
  // Date provider de l'event (different de createdAt qui est notre reception)
  providerCreatedAt DateTime
  createdAt         DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([type])
  @@index([providerCreatedAt])
}

// =====================================================
// USER
// Roles :
//  - LEARNER  : utilisateur final (sensibilisation, parcours)
//  - MANAGER  : peut consulter le reporting d'equipe (lecture seule sur /admin)
//  - RSSI     : responsable securite. Gere users, groupes, audit, force 2FA
//               et politiques de securite. Pas d'acces facturation/tenant.
//  - ADMIN    : administrateur metier du tenant (RH/IT). Idem RSSI + facturation.
//  - SUPERADMIN : exploitant plate-forme (HumaniX). Acces global, moderation.
// =====================================================
enum Role {
  LEARNER
  MANAGER
  RSSI
  ADMIN
  SUPERADMIN
}

model User {
  id            String    @id @default(cuid())
  tenantId      String
  email         String    @unique
  emailVerified DateTime?
  name          String?
  role          Role      @default(LEARNER)
  // service = champ libre legacy, conserve pour compat (ex: import CSV).
  // La gestion structuree est faite via les Group / UserGroup ci-dessous.
  service       String?
  isActive      Boolean   @default(true)

  // ----------------------------------------------------
  // AUTHENTIFICATION PAR MOT DE PASSE (optionnelle)
  // ----------------------------------------------------
  // Hash scrypt (cf. lib/password.ts). null = pas de mdp defini, l'user
  // se connecte uniquement par magic link / SSO. Permet la coexistence
  // des deux modes.
  passwordHash        String?
  passwordUpdatedAt   DateTime?
  // Lockout anti-bruteforce : compteur d'echecs consecutifs et fenetre
  // de blocage. Reset des qu'un login reussit.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  lastLoginIpHash     String?

  // ----------------------------------------------------
  // 2FA - TOTP (RFC 6238)
  // ----------------------------------------------------
  // mfaSecret = secret partage encode base32, chiffre cote app si AUTH_SECRET
  // est dispo (sinon stocke en clair, c'est moins ideal mais standard NextAuth).
  // mfaEnabled = true uniquement APRES verification d'un code (l'enrolment
  // est en 2 temps : generate -> verify -> enable).
  mfaSecret          String?
  mfaEnabled         Boolean   @default(false)
  mfaEnabledAt       DateTime?
  // Codes de secours (10 a la creation), hash scrypt comme un mot de passe
  // a usage unique. Stockes JSON-encoded array de hashes.
  mfaBackupCodesHash String?   @db.Text
  // Si forced=true, l'user est OBLIGE de configurer 2FA au prochain login.
  // Force par RSSI/ADMIN au niveau du user, ou par politique sur le role.
  mfaForced          Boolean   @default(false)

  coins             Int       @default(0)
  level             Int       @default(1)
  riskScore         Int       @default(50) // 0 = très exposé, 100 = excellent
  // ----------------------------------------------------
  // PERSONA PEDAGOGIQUE (ajout mai 2026)
  // ----------------------------------------------------
  // Adapte le ton et le niveau de detail des explications IA selon le
  // profil de l'utilisateur. null = pas explicitement defini, on infere
  // depuis le role + service + historique (cf. lib/ai/persona.ts).
  //
  // Valeurs : "beginner" | "technical" | "manager" | "developer"
  //          | "finance" | "hr" | "ops"
  // - beginner  : vocabulaire simple, analogies du quotidien
  // - technical : vocabulaire technique, IOCs, references CVE/MITRE
  // - manager   : vue strategique, ROI, conformite, vocabulaire COMEX
  // - developer : exemples code, OWASP, CI/CD, supply chain
  // - finance   : fraude au president, virement, KYC, FATF
  // - hr        : ingenierie sociale, donnees personnelles, RGPD employes
  // - ops       : continuite, sauvegarde, ransomware impact metier
  persona           String?
  mascotSpecies     String    @default("fox") // fox, cat, dog, hippo, shark, etc.
  // Emoji libre qui override mascotSpecies si renseigne (1 caractere emoji).
  // Permet a l'utilisateur de choisir n'importe quel emoji (ex: 🚀, 🌈) sans
  // se limiter au catalogue MASCOT_SPECIES. null = utilise mascotSpecies.
  mascotEmojiCustom String? // null ou emoji unicode (max 8 chars pour ZWJ sequences)
  // Humeur affichee de la mascotte. Synchro avec HexMascotEvolved Mood type.
  // Valeurs : neutral / happy / sad / curious / celebrate / thinking
  mood              String    @default("neutral")
  shareCount        Int       @default(0) // Nombre d'articles partages (badge ambassadeur)
  lastSeenAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  progress               Progress[]
  events                 Event[]
  accounts               Account[]
  sessions               Session[]
  inventory              UserInventory[]
  phishingResults        PhishingResult[]
  notificationLogs       NotificationLog[]
  authoredModules        MarketplaceModule[]     @relation("AuthoredModules")
  reviewedModules        MarketplaceModule[]     @relation("ReviewedModules")
  familyInvitesIssued    FamilyInvite[]          @relation("FamilyInviteSponsor")
  transferRequestsIssued TenantTransferRequest[] @relation("TransferRequestRequester")
  impersonationsAsAdmin  ImpersonationSession[]  @relation("ImpersonationAdmin")
  impersonationsAsTarget ImpersonationSession[]  @relation("ImpersonationTarget")
  expertProfile          ExpertProfile?
  passwordResets         PasswordResetToken[]
  groups                 UserGroup[]
  webauthnCredentials    WebAuthnCredential[]
  achievements           UserAchievement[]
  investigationResults   InvestigationResult[]
  // Memberships croisees : le user a un role admin DANS D'AUTRES tenants que
  // son home. Cas typique : un SUPERADMIN Humanix qui agit aussi comme admin
  // sur les tenants clients qu'il accompagne (cf. TenantMembership).
  tenantMemberships      TenantMembership[]      @relation("UserTenantMemberships")
  tenantMembershipsGrantedByMe TenantMembership[] @relation("TenantMembershipsGrantedBy")

  @@index([tenantId])
  @@index([isActive])
}

// =====================================================
// TENANT MEMBERSHIP - role ADDITIONNEL dans un autre tenant que son home.
// =====================================================
// Cas d'usage : un SUPERADMIN Humanix qui accompagne plusieurs tenants
// clients en tant qu'admin operatif. Sans cette table, il devrait creer
// un user distinct par tenant (lourd, audit incoherent).
//
// Semantique :
//   - User.tenantId = "home" tenant (creation, milieu naturel)
//   - User.role     = role dans le home tenant
//   - TenantMembership(userId, tenantId) = role ADDITIONNEL dans
//                                          UN AUTRE tenant
//
// Politique de creation :
//   - Cree par un SUPERADMIN via /superadmin/tenants/[id]/admins
//   - jamais auto-cree
//   - audit obligatoire (grantedBy + grantedAt + audit log)
//
// Effet sur les acces :
//   - resolveTenantContext() (lib/tenant-context.ts) reconnait le mismatch
//     si membership existe et autorise l'acces au sous-domaine.
//   - Le helper getCurrentTenantId() (a venir) renvoie le tenant resolu
//     via le sous-domaine pour les pages admin.
//
// Hierarchie (lib/role-hierarchy.ts) :
//   - Le role assigne dans le membership doit etre <= role de l'operateur
//   - L'operateur doit avoir un rang strictement superieur au user cible
//
// Ajoute 2026-05-23 a la demande de Florian.
model TenantMembership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  // Role accorde dans le tenant. Typiquement ADMIN, mais peut aussi etre
  // MANAGER ou RSSI pour limiter les droits.
  role      Role
  // Qui a accorde ce membership. Optionnel pour permettre la migration de
  // donnees historiques (avant d'avoir ce champ).
  grantedBy String?
  grantedAt DateTime @default(now())
  // Note libre (raison de l'attribution, contexte). Max ~200 chars.
  note      String?

  user        User    @relation("UserTenantMemberships", fields: [userId], references: [id], onDelete: Cascade)
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  grantedByUser User? @relation("TenantMembershipsGrantedBy", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@unique([userId, tenantId], name: "userId_tenantId")
  @@index([tenantId, role])
  @@index([userId])
}

// =====================================================
// WEBAUTHN - clés de sécurité hardware (FIDO2)
// Pour l'auth super-admin : clé Thales et-Fusion / YubiKey / Titan, etc.
// Compatible passkeys synchronisees (iCloud Keychain, 1Password) si l'user
// le souhaite, mais l'usage cible est cle USB hardware-only.
// =====================================================
model WebAuthnCredential {
  id           String    @id @default(cuid())
  userId       String
  // Identifiant unique de la cle (b64url) - stable a vie pour cette cle.
  credentialId String    @unique
  // Cle publique COSE de la cle hardware, encodee b64url. Verifiee a chaque
  // login via @simplewebauthn/server.
  publicKey    String    @db.Text
  // Compteur signed (anti-replay). Augmente a chaque utilisation.
  counter      BigInt    @default(0)
  // Transports supportes (CSV : "usb,nfc,ble,internal")
  transports   String?
  // Nom convivial choisi par l'user ("Thales et-Fusion bureau")
  deviceName   String
  // AAGUID = identifiant du modele de la cle (utile si on veut whitelister)
  aaguid       String?
  // backupEligible/backedUp : true = passkey synchronisee (iCloud, 1Password)
  // false = cle hardware-only (recommande pour SUPERADMIN)
  backedUp     Boolean   @default(false)
  // userVerified : true si la cle exige PIN/biometrie (= 2FA implicite)
  userVerified Boolean   @default(false)
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// =====================================================
// PASSWORD RESET TOKEN
// Token a usage unique pour la reinitialisation de mot de passe.
// Le token n'est PAS stocke en clair : on stocke un hash sha256.
// Expiration courte (1h) pour limiter l'exposition.
// =====================================================
model PasswordResetToken {
  id              String    @id @default(cuid())
  userId          String
  // Hash SHA-256 du token envoye par email. On compare en hashant
  // le token re-soumis (pas de fuite si la BDD est compromise).
  tokenHash       String    @unique
  expiresAt       DateTime
  usedAt          DateTime?
  // Trace forensic (RGPD) : IP hash + UA tronque
  requestedIpHash String?
  requestedUa     String?   @db.Text
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// =====================================================
// GROUPES METIER
// Un groupe = un service / departement / equipe (ex: Compta, RH, Dev,
// Commercial, Direction, IT, Atelier). Multi-tenant (chaque tenant a
// ses propres groupes). Sert a :
//  - Cibler les campagnes phishing par service
//  - Differencier les modules obligatoires
//  - Segmenter le reporting RSSI
// Un user peut appartenir a plusieurs groupes (jonction UserGroup).
// =====================================================
model Group {
  id          String   @id @default(cuid())
  tenantId    String
  // Nom affiche : "Comptabilite", "Ressources Humaines", etc.
  name        String
  // Slug technique stable pour ciblage (ex: "compta", "rh", "dev")
  slug        String
  // Emoji + description pour l'UI
  emoji       String   @default("🏷️")
  description String?
  // Couleur hex pour les badges dans le reporting (ex: "#0B3D91")
  color       String?
  // isSystem : groupes seedes (Compta/RH/Dev/Commercial...) qu'on ne peut
  // pas supprimer mais qu'on peut desactiver/renommer.
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members UserGroup[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
}

model UserGroup {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  // Si true, l'user est responsable du groupe (peut piloter les campagnes
  // phishing dediees, recevoir le reporting). Pas un role auth, juste un
  // marqueur metier.
  isLead   Boolean  @default(false)
  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =====================================================
// CATALOGUE
// =====================================================
model Saison {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  description    String
  coverEmoji     String   @default("🎯")
  order          Int      @default(0)
  isPublished    Boolean  @default(true)
  // Audience principale : "tous", "managers", "rh", "compta", "dev",
  // "dirigeants", "dpo", etc. Source : prisma/catalog-saisons.ts.
  // Sert au filtrage simple dans /admin/modules.
  audience       String   @default("tous")
  // Tags multi-positionnement pour /admin/modules. Une saison peut etre
  // taggee a la fois "metier:rh" + "rgpd" + "fondamentaux" pour permettre
  // un classement croise. Le seed (catalog-tags.ts) propose des tags par
  // defaut bases sur le slug ; l'admin peut ajouter/retirer librement.
  tags           String[] @default([])
  // Saison globale = catalogue HumaniX (tenantId null, visible a tous).
  // Saison custom = clonee depuis un module marketplace ; visible uniquement
  // au tenant proprietaire.
  tenantId       String?
  // Si la saison vient d'un module marketplace, on garde la trace pour
  // affichage badge + futures mises a jour
  sourceModuleId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant        Tenant?              @relation("TenantSaisons", fields: [tenantId], references: [id], onDelete: Cascade)
  sourceModule  MarketplaceModule?   @relation(fields: [sourceModuleId], references: [id], onDelete: SetNull)
  episodes      Episode[]
  progress      Progress[]
  tenantConfigs TenantSaisonConfig[]

  @@index([tenantId])
  @@index([sourceModuleId])
  @@index([audience])
}

model Episode {
  id              String   @id @default(cuid())
  saisonId        String
  slug            String
  title           String
  durationMinutes Int      @default(6)
  order           Int
  xpReward        Int      @default(50)
  coinsReward     Int      @default(10)
  isPublished     Boolean  @default(true)
  // ----------------------------------------------------
  // TARGETING METIER (ajout mai 2026)
  // ----------------------------------------------------
  // Liste des slugs de groupes (cf. Group.slug : "compta", "rh", "dev",
  // "direction", "it", "atelier", "communication", "agents", "commercial")
  // pour lesquels cet episode est PRIORITAIRE / specifique.
  //
  // Stocke en CSV ("compta,rh") pour rester portable Postgres + SQLite et
  // eviter une table de jointure pour 1-3 slugs par episode.
  //
  // Semantique :
  //   - null ou ""  : episode generique, montre a TOUS les users
  //   - "compta"    : prioritaire pour les users du groupe "compta"
  //   - "compta,rh" : prioritaire pour compta ET rh (OR)
  //
  // Les episodes generiques restent accessibles a tout le monde. Le
  // targeting sert juste a remonter en haut de liste les episodes
  // pertinents pour le metier de l'user (cf. /apprendre filtering).
  targetGroups    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  saison   Saison     @relation(fields: [saisonId], references: [id], onDelete: Cascade)
  progress Progress[]

  @@unique([saisonId, slug])
}

model TenantSaisonConfig {
  id          String   @id @default(cuid())
  tenantId    String
  saisonId    String
  isActive    Boolean  @default(true)
  customOrder Int?
  isMandatory Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saison Saison @relation(fields: [saisonId], references: [id], onDelete: Cascade)

  @@unique([tenantId, saisonId])
  @@index([tenantId])
}

// =====================================================
// SMTP TENANT - configuration d'envoi par tenant client
// =====================================================
// Pour les phishing simules (et futurs envois transactionnels custom),
// chaque tenant configure SON PROPRE serveur SMTP. Humanix-Cybersecurity
// ne partage PAS son SMTP : c'est a chaque client de :
//   - faire son OPSEC (nom de domaine, IP, reputation, SPF, DKIM, DMARC)
//   - assumer la responsabilite legale (envois identifies au domaine du
//     client, pas au notre)
//   - gerer la deliverabilite (les phishing simules deviennent un
//     incident de reputation pour qui les envoie)
//
// Si le client ne veut pas configurer son SMTP, il contacte Humanix
// pour une PRESTATION DE SERVICE FACTUREE AU FORFAIT (mise en place
// d'un SMTP dedie + delegation de domaine + suivi reputation).
//
// SECURITE :
//   - Le password est chiffre AES-256-GCM via une cle derivee de
//     AUTH_SECRET (cf. lib/smtp/encryption.ts). Jamais stocke en clair.
//   - Audit log a chaque create/update/delete + chaque test.
//   - Lecture restreinte ADMIN/RSSI/SUPERADMIN du tenant.
model TenantSmtpConfig {
  id             String    @id @default(cuid())
  tenantId       String    @unique
  // Adresse du serveur SMTP : smtp.gmail.com, smtp-mail.outlook.com,
  // smtp.scw-tem.cloud, mx.ovh.com, etc.
  host           String
  // 587 STARTTLS standard, 465 SSL/TLS implicite, 25 plain (a eviter).
  port           Int       @default(587)
  // true = TLS/SSL implicite (port 465). false = STARTTLS (port 587).
  secure         Boolean   @default(false)
  // Auth username : souvent l'email d'envoi ou un identifiant API.
  username       String
  // Auth password CHIFFRE AES-256-GCM (cf. lib/smtp/encryption.ts).
  // Format stocke : base64(iv) + ":" + base64(ciphertext+tag).
  passwordEnc    String    @db.Text
  // From address par defaut pour les envois (e.g. "noreply@acme.fr").
  // Doit etre dans un domaine autorise par le SPF/DKIM/DMARC du SMTP.
  fromEmail      String
  // Nom affiche dans le From ("Acme Cyber" -> "Acme Cyber <noreply@acme.fr>")
  fromName       String?
  // Statut du dernier test de connexion : null = jamais teste,
  // true = success, false = failure (lastError contient le detail).
  isVerified     Boolean?
  lastVerifiedAt DateTime?
  lastError      String?   @db.Text
  // Notes admin (optionnel, ex : "compte dedie phishing chez OVH")
  notes          String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// =====================================================
// PROGRESSION
// =====================================================
enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Progress {
  id               String         @id @default(cuid())
  tenantId         String
  userId           String
  saisonId         String
  episodeId        String
  status           ProgressStatus @default(NOT_STARTED)
  // score = XP brute gagnee sur la tentative courante (gamification).
  // Peut depasser 100 (xpReward + bonus quiz + bonus scenario).
  score            Int            @default(0)
  // bestScore = meilleure XP jamais obtenue sur cet episode (pour le total).
  bestScore        Int            @default(0)
  // quizScorePct = pourcentage de bonnes reponses au dernier quiz (0-100).
  // Utilise pour le calcul de maitrise dans risk-score.ts. Different du score
  // (XP) qui melange xpReward + bonus.
  quizScorePct     Int            @default(0)
  // bestQuizScorePct = meilleur pourcentage jamais atteint (pour reporting).
  bestQuizScorePct Int            @default(0)
  attempts         Int            @default(0)
  // ----------------------------------------------------
  // REPRISE MID-EPISODE (ajout mai 2026)
  // ----------------------------------------------------
  // Permet a l'utilisateur qui ferme l'episode au milieu (telephone,
  // urgence, fatigue) de reprendre exactement la ou il etait, pas du
  // tout debut. Persistes via POST /api/progress a chaque transition
  // de step / question.
  //
  // resumeStep : "scenario" | "debrief" | "quiz" | null (null = pas
  //   commence ou termine).
  // resumeQuizIndex : index 0-based de la question quiz en cours,
  //   utile uniquement quand resumeStep="quiz".
  // resumeChoiceId : choix scenario fait (si applicable, pour rejouer
  //   le bon debrief sans reposer la question).
  resumeStep       String?
  resumeQuizIndex  Int            @default(0)
  resumeChoiceId   String?
  startedAt        DateTime?
  completedAt      DateTime?
  updatedAt        DateTime       @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  saison  Saison  @relation(fields: [saisonId], references: [id])
  episode Episode @relation(fields: [episodeId], references: [id])

  @@unique([userId, episodeId])
  @@index([tenantId])
  @@index([userId, status])
}

