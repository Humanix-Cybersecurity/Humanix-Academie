model TeamChallenge {
  id                   String    @id @default(cuid())
  tenantId             String
  title                String
  description          String?
  startDate            DateTime
  endDate              DateTime
  isActive             Boolean   @default(true)
  // RECOMPENSES (mai 2026) — distribuees a la fin du challenge :
  //   - rewardCoins : coins bonus aux Top 3 individuels (50% / 30% / 20%
  //     du total). 0 = pas de reward coins.
  //   - rewardItemId : item exclusif debloqué pour les Top 3 si defini.
