// =====================================================
// PHISHING SIMULE
// =====================================================
enum PhishingTemplate {
  // Email phishing
  FAKE_MICROSOFT
  FAKE_COLISSIMO
  FAKE_PRESIDENT
  // SMS smishing
  SMS_FAKE_LIVREUR // "Votre colis La Poste / Chronopost - frais de livraison"
  SMS_FAKE_BANQUE // "Tentative de paiement detectee, validez via lien"
  SMS_FAKE_IMPOTS // "Trop-percu ANTS / Service Public - IBAN a verifier"
  SMS_FAKE_2FA // "Votre code 2FA est XXX, partagez-le si on vous demande"
  SMS_FAKE_PRESIDENT // "Operation confidentielle, urgent, repondez"
  // QR code quishing (poster physique, table cafe, parking, courrier)
  QR_FAKE_AMENDE // Faux QR sur amende stationnement -> faux site ANTAI
  QR_FAKE_WIFI // Faux QR "WiFi gratuit" -> vol credentials / device
  QR_FAKE_MENU // Faux QR menu restaurant -> exfiltration CB
  QR_FAKE_RH // Faux QR sur affiche RH/CSE -> phishing intra
}

enum PhishingChannel {
  EMAIL
  SMS
  QUISHING // QR code physique : pas d'envoi technique, l'admin imprime
  // l'affiche/etiquette et la pose sur le terrain (test physique)
}

enum PhishingStatus {
  SENT
  CLICKED
  REPORTED
}

model PhishingCampaign {
  id          String           @id @default(cuid())
  tenantId    String
  title       String
  template    PhishingTemplate
  // Canal d'envoi : EMAIL (phishing classique) ou SMS (smishing).
  // Le contenu pedagogique change selon le canal.
  channel     PhishingChannel  @default(EMAIL)
  // Corps du SMS si channel=SMS (max 160 chars + lien tracke ajoute).
  // Pour le phishing email le corps est dans le template, pas ici.
  smsBody     String?
  // SSID Wi-Fi affiche sur le poster pour le template QR_FAKE_WIFI.
  // Nullable : defaut "Humanix-Guest" si non specifie. Validation stricte
  // cote application : whitelist [a-zA-Z0-9 _.-], max 32 chars, anti-injection
  // QR/HTML (cf. lib/quishing/ssid-validation.ts). Ajoute 2026-05-22 a la
  // demande de Florian pour rendre les campagnes plus credibles (poster avec
  // le nom du Wi-Fi reel de l'entreprise plutot que "Humanix-Guest").
  wifiSsid    String?
  scheduledAt DateTime
  sentAt      DateTime?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  results PhishingResult[]

  @@index([tenantId])
  @@index([tenantId, channel])
}

model PhishingResult {
  id         String         @id @default(cuid())
  campaignId String
  userId     String
  trackToken String         @unique
  status     PhishingStatus @default(SENT)
  sentAt     DateTime       @default(now())
  clickedAt  DateTime?
  reportedAt DateTime?

  campaign PhishingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([trackToken])
}

// =====================================================
// NOTIFICATIONS
// =====================================================
enum NotificationType {
  REMINDER_INACTIVE
  REMINDER_MANDATORY
  WELCOME
  CERTIFICATE_READY
}

model NotificationLog {
  id       String           @id @default(cuid())
  tenantId String
  userId   String
  type     NotificationType
  channel  String           @default("email")
  status   String           @default("sent")
  payload  Json?
  sentAt   DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, sentAt])
  @@index([userId, type])
}

// =====================================================
// MARKETPLACE - Modules communautaires
// SECURITE :
//  - payload validé par Zod cote serveur (pas de HTML, longueurs max)
//  - hash SHA-256 du payload publie => integrite verifiable
//  - moderation humaine obligatoire (PENDING_REVIEW -> APPROVED/REJECTED)
//  - audit log via Event
// =====================================================
enum MarketplaceStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  DEPRECATED
}

enum MarketplaceLicense {
  CC_BY // Creative Commons - Attribution
  CC_BY_SA // Creative Commons - Attribution + Partage dans les memes conditions
  PROPRIETARY // Reserve aux modules officiels HumaniX
}

model MarketplaceModule {
  id          String @id @default(cuid())
  slug        String @unique
  title       String
  description String
  emoji       String @default("🎯")
  category    String // phishing / mdp / donnees / teletravail / fraude / reseaux / crise
  difficulty  String @default("medium") // easy / medium / hard
  language    String @default("fr")

  // Auteur
  authorId      String
  authorOrgName String? // Nom de l'organisation de l'auteur (optionnel)
  isOfficial    Boolean @default(false) // true uniquement pour modules HumaniX

  // Versioning + integrite
  version     String @default("1.0.0")
  contentHash String // SHA-256 du payload JSON normalise
  payload     Json // Contenu structure (cf. lib/marketplace/schema.ts)

  // Moderation
  status          MarketplaceStatus @default(DRAFT)
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewedById    String?
  rejectionReason String?

  // Legal
  license MarketplaceLicense @default(CC_BY_SA)

  // Stats
  installCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author        User                      @relation("AuthoredModules", fields: [authorId], references: [id], onDelete: Cascade)
  reviewedBy    User?                     @relation("ReviewedModules", fields: [reviewedById], references: [id], onDelete: SetNull)
  installations MarketplaceInstallation[]
  saisons       Saison[] // Saisons clonees a partir de ce module

  @@index([status])
  @@index([category])
  @@index([authorId])
}

model MarketplaceInstallation {
  id            String   @id @default(cuid())
  tenantId      String
  moduleId      String
  saisonId      String? // Saison clonee creee lors de l'installation
  installedAt   DateTime @default(now())
  installedById String // userId de l'admin qui a installe
  isActive      Boolean  @default(true)

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module MarketplaceModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@index([tenantId])
}

// =====================================================
// LIBRAIRIE - Micro-learning (articles courts standalone)
// =====================================================
model LibraryArticle {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String
  emoji           String   @default("📖")
  category        String // mfa / phishing / mots-de-passe / byod / grand-public / etc.
  audience        String   @default("pro") // pro / tous / famille - pour partage hors-pro
  readTimeMinutes Int      @default(5)
  body            String   @db.Text // Markdown safe-rendered (geres cote app, pas de HTML brut)
  authorName      String?
  isPublished     Boolean  @default(true)
  viewCount       Int      @default(0)
  shareCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([isPublished])
  @@index([audience])
}

// =====================================================
// MODULE POST-INCIDENT - Cyber-Reflexe
// Workflow guide de reponse a incident pour PME (RGPD art. 33 + NIS2 24h/72h).
// Chaque incident porte sa propre timeline d'actions a cocher + RetEx final.
// Reserve aux plans Pro+.
// =====================================================
enum IncidentType {
  RANSOMWARE // Rançongiciel
  DATA_LEAK // Fuite / vol de donnees
  PHISHING_VICTIM // Compromission via phishing reussi
  FRAUDE_FINANCIERE // Fraude au president / faux fournisseur
  COMPTE_COMPROMIS // Prise de controle de compte (Microsoft 365, etc.)
  INTRUSION // Intrusion systeme / serveur
  DDOS // Deni de service
  AUTRE
}

enum IncidentSeverity {
  LOW // Mineur (suspicion, contenu)
  MEDIUM // Significatif (perimetre limite)
  HIGH // Majeur (perimetre etendu)
  CRITICAL // Critique (continuite menacee, donnees sensibles)
}

enum IncidentStatus {
  OPEN // Vient d'etre cree
  IN_PROGRESS // Reponse en cours
  CONTAINED // Contenu (l'attaquant n'a plus acces)
  RESOLVED // Resolu
  CLOSED // Cloture (RetEx fait)
}

model IncidentResponse {
  id              String           @id @default(cuid())
  tenantId        String
  // Identification
  reference       String // Ex: "INC-2026-001" auto-genere
  title           String // Resume court (ex: "Compromission email DSI")
  type            IncidentType
  severity        IncidentSeverity @default(MEDIUM)
  status          IncidentStatus   @default(OPEN)
  // Contexte
  detectedAt      DateTime // Quand l'incident a ete detecte
  reportedById    String? // userId de qui a leve l'alerte
  description     String           @db.Text
  affectedSystems String?          @db.Text // Systemes / services touches
  affectedUsers   Int? // Estimation nombre d'utilisateurs touches
  dataConcerned   String?          @db.Text // Categories de donnees concernees
  // Notifications obligatoires
  cnilNotified    Boolean          @default(false)
  cnilNotifiedAt  DateTime?
  cnilReference   String? // Numero de telesignalement
  anssiNotified   Boolean          @default(false)
  anssiNotifiedAt DateTime?
  anssiReference  String?
  // Resolution
  containedAt     DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  rootCause       String?          @db.Text // Cause racine identifiee
  retexNotes      String?          @db.Text // Lecons apprises
  // Stats
  estimatedCost   Int? // Cout estime en euros
  // Meta
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actions  IncidentAction[]
  timeline IncidentTimeline[]

  @@unique([tenantId, reference])
  @@index([tenantId, status])
  @@index([tenantId, detectedAt])
}

// Action a executer (issue d'une checklist) ou ajoutee manuellement
model IncidentAction {
  id           String    @id @default(cuid())
  incidentId   String
  // Categorisation
  phase        String // h0 / h24 / h72 / w1 / retex
  category     String // confinement / notification / communication / forensic / retex
  title        String
  description  String?   @db.Text
  // Etat
  isDone       Boolean   @default(false)
  doneAt       DateTime?
  doneById     String?
  // Ordre d'affichage
  position     Int       @default(0)
  // Lien vers un document genere (modele PDF/DOCX)
  documentSlug String? // ex: "notification-cnil"

  incident IncidentResponse @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, phase, position])
}

// Journal libre des evenements (decisions, communications, points cles)
model IncidentTimeline {
  id         String   @id @default(cuid())
  incidentId String
  authorId   String?
  authorName String? // Snapshot du nom au moment de l'ecriture
  occurredAt DateTime @default(now())
  kind       String   @default("note") // note / decision / external_comm / discovery
  content    String   @db.Text
  createdAt  DateTime @default(now())

  incident IncidentResponse @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, occurredAt])
}

// =====================================================
// CYBER-ANECDOTE DU LUNDI - Newsletter hebdomadaire automatique
// Une anecdote par semaine envoyee a tous les abonnes (apprenants + leads
// publics inscrits via la home). Installe une habitude de vigilance cyber.
// =====================================================
enum AnecdoteCategory {
  RANSOMWARE // Ransomware / extorsion
  PHISHING // Phishing / social engineering
  FRAUDE // Fraude au president, fraude bancaire
  DATA_LEAK // Fuite de donnees / RGPD
  SUPPLY_CHAIN // Chaine d'approvisionnement
  HACKTIVISME // Defacement / hacktivisme
  IA_ABUS // Abus IA / deepfake
  AUTRE
}

model WeeklyAnecdote {
  id           String           @id @default(cuid())
  slug         String           @unique
  title        String // Ex: "Le CHU de Brest paralyse 3 semaines par un rancongiciel"
  // Le "punch" - 3 lignes max qui resument ce qu'il s'est passe
  summary      String           @db.Text
  // L'enseignement metier - la lecon a tirer en 1-2 phrases
  lesson       String           @db.Text
  // L'action concrete que le lecteur peut faire des aujourd'hui
  miniAction   String           @db.Text
  // Source presse / officielle
  sourceUrl    String
  sourceLabel  String // Ex: "ZDNet, 15 mars 2026"
  category     AnecdoteCategory @default(AUTRE)
  // Date de l'incident reel (pour tri chronologique)
  incidentDate DateTime
  // Programmation
  scheduledFor DateTime? // Lundi cible d'envoi
  publishedAt  DateTime? // Date d'envoi effectif (null = brouillon)
  isActive     Boolean          @default(true)
  // Stats
  sentCount    Int              @default(0)
  openCount    Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([publishedAt])
  @@index([scheduledFor])
  @@index([category])
}

model AnecdoteSubscription {
  id               String    @id @default(cuid())
  email            String    @unique
  // Source d'inscription : "homepage", "audit-flash", "tenant" (auto user), "footer"
  source           String    @default("manual")
  // Si abonnement lie a un tenant client, on garde la trace pour reporting
  tenantId         String?
  // Token unique pour desinscription one-click (RGPD)
  unsubscribeToken String    @unique
  isActive         Boolean   @default(true)
  unsubscribedAt   DateTime?
  // Stats
  emailsReceived   Int       @default(0)
  lastSentAt       DateTime?
  // RGPD
  consentTextHash  String? // Hash du texte de consentement au moment de l'inscription (preuve)
  ipHash           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([isActive])
  @@index([tenantId])
}

// =====================================================
// OPT-OUT EMAIL UNIVERSEL
// =====================================================
// Stocke les desinscriptions per (email, liste). Utilise pour TOUS les types
// de mails opt-in SAUF la newsletter Cyber-Anecdote qui a sa propre table
// AnecdoteSubscription historique.
//
// Une row = "cet email refuse de recevoir les mails de la liste X". Le check
// avant envoi se fait via lib/email/opt-out-check::isEmailOptedOut().
//
// list valeurs supportees (cf. lib/email/unsubscribe.ts::EmailListId) :
//   - "transactional" : magic link, password reset (rarement opt-out, mais
//     possible via mailto:)
//   - "admin-alerts"  : notifs admin opt-in (alerte breach, deploy, etc.)
//   - "marketing"     : nouveautes produit, conseils mensuels
model EmailOptOut {
  id        String   @id @default(cuid())
  email     String
  list      String
  // Provenance de l'opt-out : "one-click" (RFC 8058 via Gmail/Outlook),
  // "manual" (l'utilisateur clique le lien dans le mail), "preferences"
  // (depuis les parametres de son compte), "support" (demande email).
  source    String   @default("one-click")
  // Hash IP pour l'audit RGPD (preuve que la demande est venue d'un humain).
  ipHash    String?
  createdAt DateTime @default(now())

  @@unique([email, list])
  @@index([email])
}

// =====================================================
// AUDIT FLASH - Lead generation depuis le quiz public /audit-flash
// Pas de tenantId : ce sont des leads anonymes / pre-clients.
// =====================================================
enum AuditLeadStatus {
  NEW // Vient d'etre soumis
  CONTACTED // Email/RDV envoye
  QUALIFIED // Lead qualifie (entreprise pertinente)
  CONVERTED // Devenu client
  ARCHIVED // Hors cible
}

model AuditFlashSubmission {
  id               String          @id @default(cuid())
  // Identite (declarative)
  email            String
  contactName      String?
  companyName      String
  size             String // 1-9 / 10-49 / 50-249 / 250+
  sector           String // services / industrie / commerce / sante / finance / public / associatif / autre
  // Resultat
  answers          Json // { questionId: "yes" | "no" | "unsure" }
  score            Int // 0-100
  verdictLabel     String // Excellent / Solide / Fragile / À risque
  topRiskCats      String // CSV des categories en top risques (ex: "humain,donnees,identite")
  recommendedPlan  String // starter / pro / enterprise
  nis2Concerned    Boolean         @default(false)
  // CRM
  leadStatus       AuditLeadStatus @default(NEW)
  leadNotes        String?         @db.Text
  // RGPD
  consentMarketing Boolean         @default(false)
  // Meta
  ipHash           String? // Hash SHA-256 de l'IP (anti-spam, RGPD-compatible)
  userAgent        String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Traçabilite acces PDF (pentest fix #4, 2026-05-24)
  pdfAccesses AuditFlashPdfAccess[]

  @@index([leadStatus])
  @@index([createdAt])
  @@index([email])
}

// =====================================================
// AuditFlashPdfAccess - Trace des telechargements du PDF
//
// Pentest fix #4 (2026-05-24) : avant, le PDF etait accessible via
// capability-URL CUID seul, sans expiration ni audit. On a passe l'URL
// en signee HMAC (cf. lib/audit-flash/signed-urls.ts) ET on logge chaque
// acces ici pour traçabilite (RGPD art. 32 + ANSSI HG M36).
//
// Politique de retention : on garde les acces 12 mois max (cohérent avec
// la retention des soumissions). Purge auto via cron mensuel.
// =====================================================
model AuditFlashPdfAccess {
  id           String                @id @default(cuid())
  submissionId String
  ipHash       String? // SHA-256 de l'IP (RGPD-compatible)
  userAgent    String?               @db.Text
  // Statut : "ok" (signature valide) | "expired" | "bad_signature" | "missing_sig" | "no_signature"
  // "no_signature" est utilise pendant la fenetre de grace (compat ascendante).
  status       String                @default("ok")
  // Date d'expiration de la signature ayant servi a acceder (pour analyse)
  signatureExp DateTime?
  accessedAt   DateTime              @default(now())

  submission AuditFlashSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([accessedAt])
  @@index([status])
}

// =====================================================
// WEBHOOKS - Notifications sortantes Slack / Teams / generiques
// Chaque tenant peut configurer N webhooks. Les helpers fire dans
// lib/webhooks/* envoient des payloads adaptes au type cible.
// =====================================================
enum WebhookType {
  SLACK // URL https://hooks.slack.com/services/...
  TEAMS // URL Microsoft Teams Connector
  GENERIC // POST JSON simple (Zapier, n8n, custom...)
  // Presets enterprises (mai 2026) :
  JIRA // POST issue REST API ; URL = https://acme.atlassian.net/rest/api/3/issue ; secret = base64(email:apitoken)
  SERVICENOW // POST table API ; URL = https://acme.service-now.com/api/now/table/incident ; secret = base64(user:pass)
  PAGERDUTY // Events API v2 ; URL = https://events.pagerduty.com/v2/enqueue ; secret = routing_key
}

model TenantWebhook {
  id           String      @id @default(cuid())
  tenantId     String
  label        String // "Canal #cyber-team", "Webhook Zapier", etc.
  type         WebhookType
  url          String      @db.Text
  // Bitmask des evenements abonnes (cf. lib/webhooks/events.ts)
  events       String // CSV : "phishing.completed,risk.degraded,episode.completed"
  // Secret pour signature HMAC (uniquement type GENERIC)
  secret       String?
  isActive     Boolean     @default(true)
  // Stats
  successCount Int         @default(0)
  failureCount Int         @default(0)
  lastFiredAt  DateTime?
  lastError    String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
}

// =====================================================
// CYBER FAMILLE - Invitations virales offertes a 3 proches
// Quand un employe termine sa saison 1 il debloque 3 invitations
// vers sa famille (parents, conjoint, enfants). Chaque proche obtient
// un acces gratuit a /famille (articles publics) en se rappelant qu'il a
// ete invite par {sponsor} via {entreprise}. Boucle virale.
// =====================================================
enum FamilyInviteStatus {
  PENDING
  REDEEMED
  EXPIRED
  REVOKED
}

model FamilyInvite {
  id               String             @id @default(cuid())
  // Sponsor : l'employe du tenant qui offre l'invitation
  sponsorUserId    String
  sponsorTenantId  String
  // Destinataire (declaratif - on demande juste un email)
  inviteeEmail     String
  inviteeFirstName String?
  // Token public unique pour activation par lien magique
  token            String             @unique
  status           FamilyInviteStatus @default(PENDING)
  // Tracking
  sentAt           DateTime           @default(now())
  redeemedAt       DateTime?
  redeemedIpHash   String?
  expiresAt        DateTime // sentAt + 90j
  // Texte du message personnel ajoute par le sponsor (optionnel)
  personalMessage  String?            @db.Text

  sponsor       User   @relation("FamilyInviteSponsor", fields: [sponsorUserId], references: [id], onDelete: Cascade)
  sponsorTenant Tenant @relation(fields: [sponsorTenantId], references: [id], onDelete: Cascade)

  @@index([sponsorUserId])
  @@index([sponsorTenantId])
  @@index([status])
  @@index([token])
}

// =====================================================
// TENANT TRANSFER REQUEST - Rattachement RGPD-safe d'un compte
// =====================================================
//
// Cas d'usage : un admin tape l'email d'une personne pour l'inviter.
// Si l'email existe deja dans un autre tenant (ex: conjoint inscrit
// en solo avant que l'employeur ouvre un espace), on ne peut pas le
// creer a nouveau (User.email est unique global). On ne peut pas non
// plus reveler a l'admin que ce compte existe (RGPD : pas de fuite
// d'existence de comptes via enumeration).
//
// Solution : un flux de "rattachement consenti".
//   1. Admin tape l'email -> server cree un TenantTransferRequest,
//      envoie un mail a l'adresse, et retourne un message NEUTRE a
//      l'admin (« Si cette personne existe, un lien lui a ete envoye »)
//   2. L'utilisateur recoit un mail explicite : « X souhaite que vous
//      rejoigniez son espace Y. Acceptez-vous ? »
//   3. Il clique le lien, se connecte si besoin, et accepte ou refuse
//   4. Si accepte : son User.tenantId est mis a jour vers le tenant
//      cible. Ses progres / certificats restent les siens.
//   5. Audit log a chaque etape. Le lien expire en 7 jours.
model TenantTransferRequest {
  id                  String                @id @default(cuid())
  // L'admin qui a lance la demande
  requestedByUserId   String
  requestedByTenantId String
  // Email cible. Stocke meme si pas d'user correspondant, pour cacher
  // l'existence (on cree la request dans tous les cas).
  targetEmail         String
  // Token public unique pour le lien magique
  token               String                @unique
  status              TransferRequestStatus @default(PENDING)
  sentAt              DateTime              @default(now())
  expiresAt           DateTime
  acceptedAt          DateTime?
  rejectedAt          DateTime?
  // Message personnel optionnel ajoute par l'admin
  personalMessage     String?               @db.Text

  requestedBy       User   @relation("TransferRequestRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  requestedByTenant Tenant @relation("TransferRequestTenant", fields: [requestedByTenantId], references: [id], onDelete: Cascade)

  @@index([requestedByTenantId])
  @@index([token])
  @@index([targetEmail])
  @@index([status])
}

enum TransferRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  REVOKED
}

// =====================================================
// IMPERSONATION SESSION - Mode « Voir en tant que » RGPD-safe
// =====================================================
//
// Cas d'usage : un admin / RSSI doit debug le compte d'un utilisateur
// (problemes d'affichage, progres bloque, certificat manquant, etc.).
// Plutot que de demander a l'utilisateur de partager son ecran ou
// que l'admin « se logue en tant que » (risque RGPD majeur), on cree
// une session de lecture seule limitee dans le temps avec consentement
// explicite par mail.
//
// Flux :
//   1. Admin tape l'email de l'utilisateur cible + raison + duree
//      souhaitee (15min / 1h / 24h, max 24h)
//   2. Server cree une ImpersonationSession en status PENDING + envoie
//      mail explicite a l'utilisateur cible
//   3. Utilisateur clique le lien, double-clic Accepter -> session
//      passe en ACTIVE, expiresAt = now + dureeChoisie
//   4. Admin accede a /admin/voir/[sessionId] et voit le tableau de
//      bord de l'utilisateur en LECTURE SEULE (progres, certificats,
//      activite recente). Aucune action possible pour l'utilisateur.
//   5. Bandeau persistent en haut de page : « Vous voyez le compte de X
//      (XX min restantes) — Sortir »
//   6. Session expire automatiquement OU admin clique « Sortir » OU
//      utilisateur revoque depuis ses preferences
//
// SECURITE :
//   - Meme tenant uniquement (sauf SUPERADMIN cross-tenant explicite)
//   - LECTURE SEULE : pas de modification, pas d'envoi d'email,
//     pas de completion d'episode au nom de l'utilisateur
//   - Audit log de chaque acces, expiration, revocation
//   - Utilisateur peut revoquer a tout moment depuis /profil/securite
//   - Double-clic anti-prefetch pour le consentement
//
// =====================================================
model ImpersonationSession {
  id                       String                     @id @default(cuid())
  // L'admin qui demande l'acces
  adminUserId              String
  adminTenantId            String
  // L'utilisateur cible (doit consentir)
  targetUserId             String
  targetEmail              String
  // Token public unique pour le lien magique du consentement
  token                    String                     @unique
  status                   ImpersonationSessionStatus @default(PENDING)
  // Raison documentee par l'admin (visible par l'utilisateur)
  reason                   String                     @db.Text
  // Duree DEMANDEE par l'admin (en minutes, max 1440 = 24h)
  requestedDurationMinutes Int                        @default(60)
  // Timestamps
  requestedAt              DateTime                   @default(now())
  // expiresAt du LIEN de consentement (24h pour cliquer)
  consentExpiresAt         DateTime
  // grantedAt : quand l'utilisateur a accepte
  grantedAt                DateTime?
  // endsAt : quand la session ACTIVE prend fin (grantedAt + dureeChoisie)
  endsAt                   DateTime?
  // Quand la session a ete cloturee (manuellement ou auto)
  endedAt                  DateTime?
  endedReason              String? // "user_revoked" | "admin_ended" | "expired"

  adminUser   User   @relation("ImpersonationAdmin", fields: [adminUserId], references: [id], onDelete: Cascade)
  adminTenant Tenant @relation("ImpersonationAdminTenant", fields: [adminTenantId], references: [id], onDelete: Cascade)
  targetUser  User   @relation("ImpersonationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([targetUserId])
  @@index([adminTenantId])
  @@index([token])
  @@index([status])
}

enum ImpersonationSessionStatus {
  PENDING // En attente de consentement utilisateur
  ACTIVE // Consenti, en cours
  EXPIRED // Le lien de consentement a expire (jamais accepte)
  REJECTED // Utilisateur a refuse
  REVOKED // Utilisateur a revoque pendant la session active
  ENDED // Session terminee normalement (admin ou timeout)
}

// =====================================================
// EXPERT PROFILE - Bibliotheque vivante d'experts cyber francais
// Une personne (User) peut etre auteur de modules marketplace ET avoir
// un profil public expert valorisant sa contribution. C'est le levier
// communautaire qui rend la marketplace "vivante" (vs un catalogue genere
// en interne par les concurrents).
// =====================================================
model ExpertProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  // Identifiant public stable (pour /experts/:slug). Genere a la creation.
  slug          String   @unique
  // Bio publique (markdown safe-rendered cote app, pas de HTML brut)
  headline      String // titre court : "RSSI - Cabinet Dupont", "Gendarme retraite"
  bio           String   @db.Text
  organization  String? // Organisation actuelle (CHU, ANSSI, cabinet, etc.)
  // Reseaux pro (optionnel)
  linkedinUrl   String?
  websiteUrl    String?
  // Photo : URL d'avatar (uploaded ailleurs, on stocke juste le pointeur)
  avatarUrl     String?
  // Domaines d'expertise : CSV (ex: "phishing,iam,nis2,sante")
  expertiseTags String   @default("")
  // Visibilite : un profil peut etre cache temporairement (ex: l'expert quitte)
  isPublished   Boolean  @default(true)
  // Distinctions (CSV) - libre. Ex: "ANSSI cert. RSSI", "OSCP", "20 ans terrain"
  credentials   String   @default("")
  // Stats : auto-calculees, denormalisees
  modulesCount  Int      @default(0) // nb de modules APPROVED publies
  totalInstalls Int      @default(0) // somme des installations
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isPublished])
}

// =====================================================
// OBSERVATOIRE DES FUITES DE DONNEES
// Aggregation de 3 sources publiques francophones :
//  - frenchbreaches.com
//  - bonjourlafuite.eu.org
//  - fuitesinfos.fr
//
// Pas de tenantId : les fuites sont des INFOS PUBLIQUES, partagees a tous.
// Ne contient PAS de donnees fuitees, juste les metadonnees de l'incident
// (organisation victime, date, type de donnees, source). RGPD-safe.
// =====================================================
enum BreachSource {
  FRENCHBREACHES // frenchbreaches.com
  BONJOURLAFUITE // bonjourlafuite.eu.org
  FUITESINFOS // fuitesinfos.fr
  MANUAL // saisie manuelle SUPERADMIN
}

model DataBreach {
  id             String       @id @default(cuid())
  // Identifiant externe stable : utilise pour la dedup avec la source.
  // Soit un id natif scrape, soit un hash sha256(title + date) si pas d'id.
  externalId     String
  source         BreachSource
  // URL canonique de l'article source (pour citation)
  sourceUrl      String       @db.Text
  // Le titre tel que publie par la source
  title          String       @db.Text
  // Organisation victime (parsee best-effort depuis le titre)
  organization   String?
  // Pays principal de l'incident (FR par defaut pour ces 3 sources)
  country        String       @default("FR")
  // Secteur (sante / finance / education / public / etc.)
  sector         String?
  // Date de l'incident OU date de publication si incident inconnu
  incidentDate   DateTime
  // Date de scraping (pour debug)
  scrapedAt      DateTime     @default(now())
  // Resume court (max 500 chars)
  summary        String?      @db.Text
  // Nombre d'enregistrements exposes (null si non communique)
  recordsExposed Int?
  // Types de donnees fuitees (CSV : "email,nom,telephone,mdp")
  dataTypes      String?
  // Severity heuristique pour tri/affichage : "low" / "medium" / "high" / "critical"
  severity       String       @default("medium")
  // Visible dans l'observatoire public (false = caché par moderation)
  isPublished    Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Dedup forte : meme externalId par source = meme fuite
  @@unique([source, externalId])
  @@index([incidentDate])
  @@index([source, incidentDate])
  @@index([isPublished, incidentDate])
}

// =====================================================
// AUDIT LOG - Journal de conformité
//
// Distinct du modèle Event (qui sert au business / gamification).
// AuditLog trace les actions sensibles pour la conformité RGPD (accountability
// art. 5.2), NIS2, ISO 27001 (A.12.4 Logging and monitoring), ANSSI.
//
// Principes :
//  - Append-only (jamais d'UPDATE / DELETE en code applicatif)
//  - Snapshot des identités (actorEmail, actorRole) pour résister à la
//    suppression d'un compte ultérieurement.
//  - IP hashée SHA-256 (RGPD-safe - réversible uniquement avec dictionnaire)
//  - Conservation : 13 mois minimum (recommandation CNIL pour les logs
//    sécurité, à aligner avec votre politique). Purge gérée par
//    scripts/purge-old-audit-logs.ts.
// =====================================================
enum AuditAction {
  // Authentification
  USER_LOGIN_SUCCESS
  USER_LOGIN_FAILED
  USER_LOGOUT
  USER_LOCKED
  USER_UNLOCKED
  USER_PASSWORD_CHANGED
  USER_PASSWORD_RESET_REQUESTED
  USER_PASSWORD_RESET_USED
  USER_MFA_ENABLED
  USER_MFA_DISABLED
  USER_MFA_FORCED
  USER_MFA_RESET_BY_ADMIN
  USER_WEBAUTHN_REGISTERED
  USER_WEBAUTHN_DELETED
  USER_WEBAUTHN_LOGIN
  // Lifecycle utilisateur
  USER_INVITED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_ACTIVATED
  USER_SUSPENDED
  USER_ROLE_CHANGED
  USER_GROUPS_CHANGED
  // Rattachement cross-tenant (RGPD-safe)
  TRANSFER_REQUEST_CREATED // Admin a demande le rattachement d'un email
  TRANSFER_REQUEST_ACCEPTED // L'utilisateur cible a accepte
  TRANSFER_REQUEST_REJECTED // L'utilisateur cible a refuse
  TRANSFER_REQUEST_REVOKED // Admin a annule sa demande
  // Mode « Voir en tant que » (impersonation read-only)
  IMPERSONATION_REQUESTED // Admin a demande l'acces en lecture
  IMPERSONATION_GRANTED // L'utilisateur cible a accepte
  IMPERSONATION_REJECTED // L'utilisateur cible a refuse
  IMPERSONATION_REVOKED // L'utilisateur cible a revoque pendant l'acces
  IMPERSONATION_ENDED // L'admin a clos la session ou timeout
  IMPERSONATION_VIEW // Admin a consulte une page pendant la session
  // Tenant
  TENANT_CREATED
  TENANT_UPDATED
  TENANT_DELETED
  TENANT_DEACTIVATED
  TENANT_REACTIVATED
  TENANT_USERS_VIEWED // SUPERADMIN a consulte la liste users d'un tenant
  // Multi-tenant membership (SUPERADMIN gere les admins d'un tenant 2026-05-23)
  TENANT_MEMBERSHIP_GRANTED // Admin externe ajoute via TenantMembership
  TENANT_MEMBERSHIP_REVOKED // Membership retire
  TENANT_MEMBERSHIP_UPDATED // Role du membership modifie (MANAGER -> ADMIN, etc.)
  USER_CREATED_BY_SUPERADMIN // Nouvel admin natif cree directement via panel SUPERADMIN
  // Groupes
  GROUP_CREATED
  GROUP_UPDATED
  GROUP_DELETED
  // Billing
  BILLING_CHECKOUT_STARTED
  BILLING_SUBSCRIPTION_CREATED
  BILLING_SUBSCRIPTION_UPDATED
  BILLING_SUBSCRIPTION_CANCELED
  BILLING_PAYMENT_FAILED
  BILLING_PORTAL_ACCESSED
  // RGPD - Droits des personnes
  DATA_ACCESSED // art. 15 - l'user consulte ses donnees
  DATA_EXPORTED // art. 20 - portabilite (download JSON)
  DATA_ERASURE_REQUESTED // art. 17 - demande d'effacement
  DATA_ERASURE_COMPLETED // art. 17 - effacement effectue
  DATA_RETENTION_CONFIGURED // art. 5.1.e - admin a defini Tenant.dataRetentionDays
  DATA_RETENTION_PURGED // art. 5.1.e - cron a purge des donnees > seuil
  CONSENT_GIVEN
  CONSENT_WITHDRAWN
  // Securite / divers
  API_KEY_CREATED
  API_KEY_REVOKED
  EVIDENCE_BUNDLE_EXPORTED
  // Phishing simulation (cron + reporting)
  PHISHING_CAMPAIGN_CREATED
  PHISHING_CAMPAIGN_SENT // Le cron a declenche l'envoi
  PHISHING_REPORT_EXPORTED // Admin a telecharge le CSV
  // SMTP tenant (config + tests + envois)
  TENANT_SMTP_CONFIGURED // Admin a sauve une config SMTP
  TENANT_SMTP_TESTED // Admin a teste la connexion (succes ou echec)
  TENANT_SMTP_DELETED // Admin a supprime la config (perte des credentials)
  // CISO Assistant (connexion + sync)
  CISO_CONNECTION_CONFIGURED // Admin a sauve les credentials d'une instance CISO Assistant
  CISO_CONNECTION_TESTED // Admin a teste la connexion (login + GET folders)
  CISO_CONNECTION_DELETED // Admin a retire les credentials
  CISO_SYNC_STARTED // Sync evidence push vers CISO Assistant lancee
  CISO_SYNC_COMPLETED // Sync terminee avec succes
  CISO_SYNC_FAILED // Sync interrompue par erreur
  CISO_LIVE_SYNC // Mini-sync incrementale declenchee par un evenement metier (Live Mode v2.0)
  // Securite IA (pentest fix 2026-05-24)
  AI_PROMPT_INJECTION_ATTEMPT // Filtre output Hex a detecte une tentative de fuite du system prompt
  AI_OUTPUT_LEAK_BLOCKED // Stream Hex coupe par defense en profondeur (signature prompt detectee)
  // Detection exfiltration (pentest fix #8 sprint 3 - 2026-05-24)
  EXFILTRATION_SUSPECTED // Seuil rolling window depasse sur /api/admin/*/export
  // Connecteur Privacy Tools dedie DPO (2026-05-24)
  DPO_EXPORT_REQUESTED // Export JSON via /api/v1/dpo-export (OneTrust, Didomi, Privacy.fr)
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  DENIED // refus d'autorisation (forbidden)
}

enum AuditSeverity {
  INFO
  NOTICE
  WARNING
  CRITICAL
}

model AuditLog {
  id          String        @id @default(cuid())
  tenantId    String? // null pour les actions cross-tenant SUPERADMIN
  // Acteur - snapshot pour resister a la suppression
  actorUserId String? // null si systeme / pre-auth (ex: login failed)
  actorEmail  String? // snapshot au moment du log
  actorRole   String? // snapshot
  // Action
  action      AuditAction
  outcome     AuditOutcome
  severity    AuditSeverity @default(INFO)
  // Cible (optionnelle)
  targetType  String? // "user", "tenant", "group", "subscription", ...
  targetId    String?
  targetLabel String? // snapshot lisible (email, nom, slug)
  // Contexte technique
  ipHash      String? // SHA-256 hex (RGPD-safe)
  userAgent   String?       @db.Text
  message     String?       @db.Text
  metadata    Json?

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([severity, createdAt])
}

// =====================================================
// EVENEMENTS
// =====================================================
model Event {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  type      String
  payload   Json
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([type])
}

// =====================================================
// ACHIEVEMENT - badges debloquables persistes en BDD (mai 2026)
// =====================================================
// Avant : les badges etaient hardcoded en React dans /apprendre/page.tsx
// (12 badges, conditions inline, pas d'historique d'unlock).
// Maintenant :
//   - Achievement     = catalogue (slug + criteria definies en lib/)
//   - UserAchievement = trace d'unlock par user (date + tenant pour
//     scoping reporting RSSI)
// Le catalogue est seedé depuis lib/achievements/catalog.ts au seed +
// upserté a chaque deploy (CI) si on ajoute des nouveaux badges.
// =====================================================
model Achievement {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  emoji       String
  description String
  // Categorie pour grouper visuellement : "progression" (XP, niveaux),
  // "consistency" (streak, regularite), "mastery" (sans-faute),
  // "social" (partage, ambassadeur), "special" (events, saisons cyber)
  category    String
  // Rarete affichage : "common" / "rare" / "epic" / "legendary"
  rarity      String   @default("common")
  // Points de gloire (independants de l'XP gameplay) : sert au futur
  // classement des collectionneurs de badges.
  points      Int      @default(10)
  // Si true, le badge est masque tant qu'il n'est pas debloque (pour
  // creer la surprise sur les badges rares / events). Sinon visible
  // dans la collection avec une silhouette grisee.
  isSecret    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unlocks UserAchievement[]

  @@index([category])
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  // tenantId denormalise pour reporting RSSI (top collectionneurs par
  // tenant) sans JOIN. Source de verite = User.tenantId.
  tenantId      String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([tenantId, unlockedAt])
}

// =====================================================
// CYBER EVENT INSTANCE - instances d'evenements cyber par tenant
// =====================================================
// Le CATALOGUE des evenements cyber (Cybermois, World Password Day, etc.)
// est dans lib/events/calendar.ts (pas en BDD). Cette table store les
// INSTANCES declenchees pour un tenant donne avec metadonnees :
//   - dates effectives (calculees par event-type ex "1er jeudi de mai")
//   - challengeId du TeamChallenge auto-cree pendant l'event (si app)
//   - idempotence : un event donne ne se declenche qu'une fois par
//     tenant par annee (@@unique([tenantId, eventSlug]))
// =====================================================
model CyberEventInstance {
  id               String   @id @default(cuid())
  tenantId         String
  // Slug normalise avec annee : "world_password_day_2026",
  // "cybermois_2026", "data_protection_day_2026"
  eventSlug        String
  startDate        DateTime
  endDate          DateTime
  // ID du TeamChallenge auto-cree pour cet event (si applicable).
  // Permet de retrouver "le challenge Cybermois 2026 c'etait celui-la".
  challengeId      String?
  coinsDistributed Int      @default(0)
  createdAt        DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, eventSlug])
  @@index([tenantId, startDate])
}

// =====================================================
// CISO ASSISTANT INTEGRATION
// =====================================================
// Permet a un tenant de connecter son instance CISO Assistant (intuitem)
// et de synchroniser les evidences de conformite Humanix vers la GRC du
// client en 1-clic depuis l'admin. Cf. lib/ciso-assistant-client.ts +
// app/admin/integrations/ciso-assistant/page.tsx.

model CisoAssistantConnection {
  id                    String    @id @default(cuid())
  tenantId              String    @unique
  baseUrl               String // ex: https://ciso.client.fr
  username              String // email du compte CISO Assistant (Knox auth)
  // Password chiffre AES-256-GCM (cf. lib/crypto.ts:encryptSecret).
  // Format stocke : "<iv_b64>:<authTag_b64>:<ciphertext_b64>".
  passwordEnc           String    @db.Text
  folderName            String    @default("Humanix Académie")
  // Owner designe (RSSI ou DPO du tenant). Optionnel, embedded dans la
  // description de chaque evidence pour traçabilite audit ISO 27001 §7.5.
  // En v1.2 : creation d'un Actor CISO Assistant lié a un User cote intuitem.
  ownerEmail            String?
  // v1.3 toggles : extensions optionnelles, par defaut desactivees.
  // Principe : zero inertie entre Humanix et CISO Assistant. L'admin
  // active ce qu'il veut, peut tout couper sans casser le push d'evidences.
  // Cf. lib/ciso-assistant/sync.ts pour le branchement.
  // - createAppliedControls : creer un AppliedControl "Programme
  //   sensibilisation Humanix" lie aux evidences poussees.
  // - createFindings : a chaque sync, generer des Findings actionnables
  //   pour les controles en statut partial ou non_compliant (P1/P2 +
  //   ETA +30j).
  createAppliedControls Boolean   @default(false)
  createFindings        Boolean   @default(false)
  // v1.4 toggle : si tenant_score < 0.4 OU phishingReportRate < 0.2,
  // genere un RiskScenario "Risque humain eleve" sous un RiskAssessment
  // dedie Humanix. Necessite qu'une RiskMatrix soit chargee cote CISO
  // Assistant (sinon WARN + skip). Cf. lib/ciso-assistant/sync.ts.
  createRiskScenarios   Boolean   @default(false)
  // v1.5 toggle : si l'ownerEmail est defini, crée le User correspondant
  // dans CISO Assistant (s'il n'existe pas) puis assigne son Actor comme
  // owner sur les evidences, findings et risk scenarios poussés. Permet
  // d'avoir un responsable nommé côté GRC. Necessite permissions admin
  // sur l'instance CISO Assistant.
  syncOwnerAsActor      Boolean   @default(false)
  // v1.6 toggle : ouvre un Incident côté CISO Assistant si au moins
  // un contrôle est non_compliant sur le panel. Severite par defaut
  // SEV3 (Moderate). Sert d'alerte proactive type NIS2 §23 pour le
  // RSSI : "ta couverture humaine présente un signal d'alerte".
  // Idempotent par ref_id = "humanix-{framework}-{date YYYY-MM-DD}".
  createIncidents       Boolean   @default(false)
  // v1.7 toggle : a chaque sync, pousse une serie temporelle de samples
  // dans le module Metrology de CISO Assistant (CustomMetricSample). Le
  // RSSI / DSI / DPO peut visualiser dans les dashboards CISO Assistant
  // natifs l'evolution dans le temps : tenant_score, completion_rate,
  // phishing_report_rate, counts d'evidences par statut. 6 metriques par
  // sync. Necessite que le folder Humanix existe.
  pushMetrologySamples  Boolean   @default(false)
  // v1.8 toggle : synchronise les Groups Humanix (Compta, RH, Dev,
  // Commercial...) comme Team CISO Assistant. Permet d'assigner des
  // findings/incidents par equipe nativement dans CISO Assistant.
  // Membres pseudonymises (hash SHA-256) -- pas d'export PII brut.
  syncGroupsAsTeams     Boolean   @default(false)
  // v1.9 toggle : pour chaque PhishingCampaign Humanix active ou recente
  // (90 jours), cree/maintient une Campaign CISO Assistant. Permet au
  // RSSI de suivre ses campagnes phishing simule dans son cockpit GRC
  // habituel, sans repli sur Humanix.
  syncCampaigns         Boolean   @default(false)
  // v2.0 Live Mode : si actif, chaque evenement metier (episode.completed,
  // phishing.reported, phishing.user_clicked) declenche une mini-sync
  // incrementale debouncee (5s) sur les frameworks deja synchronises au
  // moins une fois. Permet au RSSI de voir le score remonter en temps reel
  // pendant une presentation COMEX, sans attendre le cron quotidien.
  // - Re-upsert des evidences uniquement (pas de PDF, pas d'extensions).
  // - Fire-and-forget : un echec ne bloque jamais l'evenement metier.
  // - Coalesce via debouncer : 50 evenements en 5s = 1 seule sync.
  enableLiveMode        Boolean   @default(false)
  // Telemetrie Live Mode (informationnel, mis a jour apres chaque mini-sync).
  lastLiveSyncAt        DateTime?
  lastLiveSyncEvent     String? // "episode.completed" | "phishing.reported" | "phishing.user_clicked"
  liveSyncCount         Int       @default(0)
  // v2.2 Enrichissements (audit OpenAPI v0.7) :
  // - createWorkforceAsset : push un Asset primary "Personnel · Couche
  //   humaine Humanix Académie" dans le folder, scope par defaut pour les
  //   RiskScenarios/Findings/Incidents. Permet de cartographier la
  //   couche humaine comme un asset GRC explicite.
  createWorkforceAsset  Boolean   @default(false)
  // - syncThreats : push les 15 menaces humaines Humanix (FOVI, vishing,
  //   deepfake CEO, smishing, quishing, etc.) comme Threat entities
  //   dans le folder. Permet au RSSI de les linker a ses RiskScenarios.
  syncThreats           Boolean   @default(false)
  // - createDashboard : pre-cree un Dashboard "Cockpit Humanix Académie"
  //   avec 6 widgets pointant sur les MetricInstances poussees par
  //   pushMetrologySamples. Effet "ouvre la boite c'est joli" en demo.
  //   Necessite pushMetrologySamples=true (sinon les widgets n'ont pas
  //   de cible).
  createDashboard       Boolean   @default(false)
  verifySSL             Boolean   @default(true)
  // Dernier resultat du bouton "Tester la connexion".
  lastTestedAt          DateTime?
  lastTestStatus        String? // "ok" | "auth_failed" | "unreachable" | "schema_error"
  lastTestError         String?   @db.Text // message brut si echec
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runs   CisoAssistantSyncRun[]
}

model CisoAssistantSyncRun {
  id             String    @id @default(cuid())
  tenantId       String
  connectionId   String
  framework      String // ISO27001:2022, NIS2, RGPD, ANSSI-HG, NIST-CSF
  status         String // "running" | "success" | "partial" | "failed"
  // User qui a clique sur "Synchroniser" (cron = null).
  triggeredBy    String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  evidencesTotal Int       @default(0)
  evidencesOk    Int       @default(0)
  evidencesFail  Int       @default(0)
  // Log accumule ligne par ligne pendant l'execution, lu en SSE par l'UI.
  // Format : chaque ligne = "<ISO_timestamp> [<level>] <message>".
  logs           String    @default("") @db.Text

  tenant     Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection CisoAssistantConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([tenantId, startedAt])
  @@index([status])
}

// =====================================================
// MODE ENQUETEUR — apprentissage par decouverte guidee (mai 2026)
// =====================================================
// L'apprenant analyse un media (email, post LinkedIn, photo bureau...)
// et coche les "red flags" qu'il identifie. Score = somme des red flags
// trouves - somme des penalites pour faux positifs (distractors).
//
// Difference avec un Quiz classique :
//   - Quiz = QCM avec 1 bonne reponse parmi 4
//   - Enquete = QCM "tout ce qui s'applique" avec faux positifs penalises
//
// Le contenu source (red flags + distractors + media + explications) vit
// dans le frontmatter MDX (cf. content/enquetes-demo/*.mdx pour les 3
// gratuits OSS, content-pro/content/enquetes/ pour les payants).
// La table InvestigationResult stocke uniquement les RESULTATS par user.
//
// Cf. ROADMAP_MODE_ENQUETEUR.md (hors repo) pour la stratégie complète.

enum InvestigationType {
  EMAIL // mail de phishing
  SMS // SMS de smishing
  LINKEDIN // post LinkedIn d'oversharing pro
  FACEBOOK // post Facebook d'oversharing perso
  PROFILE_PUBLIC // profil public exposant trop d'info
  PHOTO_OFFICE // photo de bureau (post-it MdP, ecran ouvert...)
  PHOTO_PIGGYBACK // photo d'un sas badge avec tailgating
  TRASH_BIN // photo de poubelle avec doc sensible
  PUBLIC_WIFI // photo en lieu public avec ecran visible
}

model InvestigationResult {
  id              String            @id @default(cuid())
  tenantId        String
  userId          String
  // Slug de l'enquete (ref vers le fichier MDX). Pas de FK car le catalogue
  // d'enquetes vit en MDX (versionne dans le repo / submodule), pas en DB.
  scenarioSlug    String
  scenarioType    InvestigationType
  // IDs des red flags coches correctement (ex: ["typosquat", "urgency"])
  redFlagsFound   Json
  // IDs des distractors coches a tort (ex: ["html_format"])
  distractorsHit  Json
  // Score net = sum(redFlags points) - sum(distractors penalty)
  score           Int
  // Score max possible (= sum de tous les redFlags points). Permet de
  // calculer le % de reussite sans recharger le MDX.
  maxScore        Int
  // Temps mis pour completer (sert au mode chronometre + leaderboard)
  durationSeconds Int
  // True si score >= seuil (60% du max). Sert au calcul du rank Detective.
  passed          Boolean           @default(false)
  createdAt       DateTime          @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, scenarioSlug])
  @@index([userId, passed])
  @@index([tenantId, createdAt])
}
