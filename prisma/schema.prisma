// HumaniX Academy - Schema BDD V0.5
// Multi-tenant logique : tout est filtre par tenantId

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// TENANT
// Multi-etablissements : un Tenant peut avoir un parent (groupe / siege).
// Le tenant racine = le contrat commercial. Les enfants = sites / agences /
// BU / etablissements. La facturation reste au niveau du tenant racine,
// le reporting est consolide.
// =====================================================
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("trial")
  // Multi-etablissements : un tenant peut avoir un parent (groupe / siege)
  parentTenantId String?
  // Type d'etablissement libre (ex : "siege", "agence", "site", "boutique")
  // Affiche dans le breadcrumb / dashboard. null pour les tenants racine.
  establishmentType String?
  // ----------------------------------------------------
  // BILLING (provider-agnostique : Payplug FR par defaut, possible Stripe)
  // ----------------------------------------------------
  // Identifie le prestataire de paiement actif pour ce tenant.
  // Valeurs : "payplug", "stripe", null (pas encore d'abonnement payant).
  paymentProvider      String?
  // Identifiants opaques chez le prestataire. Le format depend du provider
  // (Payplug : "cus_xxx", Stripe : "cus_xxx", interchangeables coté schema).
  paymentCustomerId     String?  @unique
  paymentSubscriptionId String?  @unique
  // Statut normalise : trialing, active, past_due, canceled, incomplete, etc.
  // Source de verite = webhook du provider. Synchro a chaque event subscription.
  subscriptionStatus   String?
  // Fin de la periode de facturation courante (renouvellement automatique
  // OU coupure du service si subscriptionStatus=canceled).
  currentPeriodEnd     DateTime?
  // Numero de seats facturees (relevant pour Solo/Essentielle/Pro qui ont
  // un plafond). Null si plan flat-fee ou plan gratuit.
  seatCount            Int?
  // Trial en cours : la fin (ne pas confondre avec le plan "trial" du
  // catalogue lib/plans.ts).
  trialEndsAt          DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent              Tenant?                   @relation("TenantHierarchy", fields: [parentTenantId], references: [id], onDelete: SetNull)
  children            Tenant[]                  @relation("TenantHierarchy")

  users               User[]
  saisons             Saison[]                  @relation("TenantSaisons")
  progress            Progress[]
  events              Event[]
  saisonConfigs       TenantSaisonConfig[]
  challenges          TeamChallenge[]
  apiKeys             ApiKey[]
  phishingCampaigns   PhishingCampaign[]
  notificationLogs    NotificationLog[]
  marketplaceInstalls MarketplaceInstallation[]
  webhooks            TenantWebhook[]
  familyInvites       FamilyInvite[]
  incidents           IncidentResponse[]

  @@index([parentTenantId])
}

// =====================================================
// BILLING - audit trail des events du prestataire de paiement
// Enregistre chaque webhook recu pour traçabilite (debug + RGPD).
// Les events sont aussi appliques au Tenant en parallele (statut, period
// end, seats), mais cette table garde l'historique brut.
// Provider-agnostique (payplug, stripe, ...).
// =====================================================
model BillingEvent {
  id              String   @id @default(cuid())
  // Identifie le prestataire de paiement (payplug, stripe, ...).
  provider        String   @default("payplug")
  // Hash unique d'idempotence pour eviter de traiter 2 fois le meme webhook
  // (le provider peut renvoyer le meme event plusieurs fois). Format
  // dependant du provider (Payplug : payment ID + status, Stripe : event.id).
  providerEventId String   @unique
  type            String   // ex: subscription.updated, payment.paid
  // Le tenant cible (peut etre null si on ne reconnait pas encore le customer
  // au moment du webhook, par ex. checkout completed orphelin)
  tenantId        String?
  // Snapshot du payload brut pour debug. Limite a 64 KB par Prisma.
  payload         Json
  // Resultat du traitement : "applied", "ignored", "error"
  status          String   @default("applied")
  errorMessage    String?
  // Date provider de l'event (different de createdAt qui est notre reception)
  providerCreatedAt DateTime
  createdAt       DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([type])
  @@index([providerCreatedAt])
}

// =====================================================
// USER
// Roles :
//  - LEARNER  : utilisateur final (sensibilisation, parcours)
//  - MANAGER  : peut consulter le reporting d'equipe (lecture seule sur /admin)
//  - RSSI     : responsable securite. Gere users, groupes, audit, force 2FA
//               et politiques de securite. Pas d'acces facturation/tenant.
//  - ADMIN    : administrateur metier du tenant (RH/IT). Idem RSSI + facturation.
//  - SUPERADMIN : exploitant plate-forme (HumaniX). Acces global, moderation.
// =====================================================
enum Role {
  LEARNER
  MANAGER
  RSSI
  ADMIN
  SUPERADMIN
}

model User {
  id            String    @id @default(cuid())
  tenantId      String
  email         String    @unique
  emailVerified DateTime?
  name          String?
  role          Role      @default(LEARNER)
  // service = champ libre legacy, conserve pour compat (ex: import CSV).
  // La gestion structuree est faite via les Group / UserGroup ci-dessous.
  service       String?
  isActive      Boolean   @default(true)

  // ----------------------------------------------------
  // AUTHENTIFICATION PAR MOT DE PASSE (optionnelle)
  // ----------------------------------------------------
  // Hash scrypt (cf. lib/password.ts). null = pas de mdp defini, l'user
  // se connecte uniquement par magic link / SSO. Permet la coexistence
  // des deux modes.
  passwordHash       String?
  passwordUpdatedAt  DateTime?
  // Lockout anti-bruteforce : compteur d'echecs consecutifs et fenetre
  // de blocage. Reset des qu'un login reussit.
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  lastLoginIpHash     String?

  // ----------------------------------------------------
  // 2FA - TOTP (RFC 6238)
  // ----------------------------------------------------
  // mfaSecret = secret partage encode base32, chiffre cote app si AUTH_SECRET
  // est dispo (sinon stocke en clair, c'est moins ideal mais standard NextAuth).
  // mfaEnabled = true uniquement APRES verification d'un code (l'enrolment
  // est en 2 temps : generate -> verify -> enable).
  mfaSecret           String?
  mfaEnabled          Boolean  @default(false)
  mfaEnabledAt        DateTime?
  // Codes de secours (10 a la creation), hash scrypt comme un mot de passe
  // a usage unique. Stockes JSON-encoded array de hashes.
  mfaBackupCodesHash  String?  @db.Text
  // Si forced=true, l'user est OBLIGE de configurer 2FA au prochain login.
  // Force par RSSI/ADMIN au niveau du user, ou par politique sur le role.
  mfaForced           Boolean  @default(false)

  coins         Int       @default(0)
  level         Int       @default(1)
  riskScore     Int       @default(50) // 0 = très exposé, 100 = excellent
  mascotSpecies String    @default("fox") // fox, cat, dog, hippo, shark, etc.
  // Emoji libre qui override mascotSpecies si renseigne (1 caractere emoji).
  // Permet a l'utilisateur de choisir n'importe quel emoji (ex: 🚀, 🌈) sans
  // se limiter au catalogue MASCOT_SPECIES. null = utilise mascotSpecies.
  mascotEmojiCustom String? // null ou emoji unicode (max 8 chars pour ZWJ sequences)
  // Humeur affichee de la mascotte. Synchro avec HexMascotEvolved Mood type.
  // Valeurs : neutral / happy / sad / curious / celebrate / thinking
  mood          String    @default("neutral")
  shareCount    Int       @default(0) // Nombre d'articles partages (badge ambassadeur)
  lastSeenAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  progress         Progress[]
  events           Event[]
  accounts         Account[]
  sessions         Session[]
  inventory        UserInventory[]
  phishingResults  PhishingResult[]
  notificationLogs NotificationLog[]
  authoredModules  MarketplaceModule[] @relation("AuthoredModules")
  reviewedModules  MarketplaceModule[] @relation("ReviewedModules")
  familyInvitesIssued FamilyInvite[] @relation("FamilyInviteSponsor")
  expertProfile    ExpertProfile?
  passwordResets   PasswordResetToken[]
  groups           UserGroup[]
  webauthnCredentials WebAuthnCredential[]

  @@index([tenantId])
  @@index([isActive])
}

// =====================================================
// WEBAUTHN - clés de sécurité hardware (FIDO2)
// Pour l'auth super-admin : clé Thales et-Fusion / YubiKey / Titan, etc.
// Compatible passkeys synchronisees (iCloud Keychain, 1Password) si l'user
// le souhaite, mais l'usage cible est cle USB hardware-only.
// =====================================================
model WebAuthnCredential {
  id             String   @id @default(cuid())
  userId         String
  // Identifiant unique de la cle (b64url) - stable a vie pour cette cle.
  credentialId   String   @unique
  // Cle publique COSE de la cle hardware, encodee b64url. Verifiee a chaque
  // login via @simplewebauthn/server.
  publicKey      String   @db.Text
  // Compteur signed (anti-replay). Augmente a chaque utilisation.
  counter        BigInt   @default(0)
  // Transports supportes (CSV : "usb,nfc,ble,internal")
  transports     String?
  // Nom convivial choisi par l'user ("Thales et-Fusion bureau")
  deviceName     String
  // AAGUID = identifiant du modele de la cle (utile si on veut whitelister)
  aaguid         String?
  // backupEligible/backedUp : true = passkey synchronisee (iCloud, 1Password)
  // false = cle hardware-only (recommande pour SUPERADMIN)
  backedUp       Boolean  @default(false)
  // userVerified : true si la cle exige PIN/biometrie (= 2FA implicite)
  userVerified   Boolean  @default(false)
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime?

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// =====================================================
// PASSWORD RESET TOKEN
// Token a usage unique pour la reinitialisation de mot de passe.
// Le token n'est PAS stocke en clair : on stocke un hash sha256.
// Expiration courte (1h) pour limiter l'exposition.
// =====================================================
model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  // Hash SHA-256 du token envoye par email. On compare en hashant
  // le token re-soumis (pas de fuite si la BDD est compromise).
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  // Trace forensic (RGPD) : IP hash + UA tronque
  requestedIpHash String?
  requestedUa     String? @db.Text
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// =====================================================
// GROUPES METIER
// Un groupe = un service / departement / equipe (ex: Compta, RH, Dev,
// Commercial, Direction, IT, Atelier). Multi-tenant (chaque tenant a
// ses propres groupes). Sert a :
//  - Cibler les campagnes phishing par service
//  - Differencier les modules obligatoires
//  - Segmenter le reporting RSSI
// Un user peut appartenir a plusieurs groupes (jonction UserGroup).
// =====================================================
model Group {
  id          String   @id @default(cuid())
  tenantId    String
  // Nom affiche : "Comptabilite", "Ressources Humaines", etc.
  name        String
  // Slug technique stable pour ciblage (ex: "compta", "rh", "dev")
  slug        String
  // Emoji + description pour l'UI
  emoji       String   @default("🏷️")
  description String?
  // Couleur hex pour les badges dans le reporting (ex: "#0B3D91")
  color       String?
  // isSystem : groupes seedes (Compta/RH/Dev/Commercial...) qu'on ne peut
  // pas supprimer mais qu'on peut desactiver/renommer.
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     UserGroup[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
}

model UserGroup {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  // Si true, l'user est responsable du groupe (peut piloter les campagnes
  // phishing dediees, recevoir le reporting). Pas un role auth, juste un
  // marqueur metier.
  isLead    Boolean  @default(false)
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =====================================================
// CATALOGUE
// =====================================================
model Saison {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  coverEmoji  String   @default("🎯")
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  // Saison globale = catalogue HumaniX (tenantId null, visible a tous).
  // Saison custom = clonee depuis un module marketplace ; visible uniquement
  // au tenant proprietaire.
  tenantId    String?
  // Si la saison vient d'un module marketplace, on garde la trace pour
  // affichage badge + futures mises a jour
  sourceModuleId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant?              @relation("TenantSaisons", fields: [tenantId], references: [id], onDelete: Cascade)
  sourceModule  MarketplaceModule?   @relation(fields: [sourceModuleId], references: [id], onDelete: SetNull)
  episodes      Episode[]
  progress      Progress[]
  tenantConfigs TenantSaisonConfig[]

  @@index([tenantId])
  @@index([sourceModuleId])
}

model Episode {
  id              String   @id @default(cuid())
  saisonId        String
  slug            String
  title           String
  durationMinutes Int      @default(6)
  order           Int
  xpReward        Int      @default(50)
  coinsReward     Int      @default(10)
  isPublished     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  saison   Saison     @relation(fields: [saisonId], references: [id], onDelete: Cascade)
  progress Progress[]

  @@unique([saisonId, slug])
}

model TenantSaisonConfig {
  id          String   @id @default(cuid())
  tenantId    String
  saisonId    String
  isActive    Boolean  @default(true)
  customOrder Int?
  isMandatory Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saison Saison @relation(fields: [saisonId], references: [id], onDelete: Cascade)

  @@unique([tenantId, saisonId])
  @@index([tenantId])
}

// =====================================================
// PROGRESSION
// =====================================================
enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Progress {
  id          String         @id @default(cuid())
  tenantId    String
  userId      String
  saisonId    String
  episodeId   String
  status      ProgressStatus @default(NOT_STARTED)
  // score = XP brute gagnee sur la tentative courante (gamification).
  // Peut depasser 100 (xpReward + bonus quiz + bonus scenario).
  score       Int            @default(0)
  // bestScore = meilleure XP jamais obtenue sur cet episode (pour le total).
  bestScore   Int            @default(0)
  // quizScorePct = pourcentage de bonnes reponses au dernier quiz (0-100).
  // Utilise pour le calcul de maitrise dans risk-score.ts. Different du score
  // (XP) qui melange xpReward + bonus.
  quizScorePct Int           @default(0)
  // bestQuizScorePct = meilleur pourcentage jamais atteint (pour reporting).
  bestQuizScorePct Int       @default(0)
  attempts    Int            @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime       @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  saison  Saison  @relation(fields: [saisonId], references: [id])
  episode Episode @relation(fields: [episodeId], references: [id])

  @@unique([userId, episodeId])
  @@index([tenantId])
  @@index([userId, status])
}

// =====================================================
// BOUTIQUE
// =====================================================
enum ItemCategory {
  HAT
  GLASSES
  ACCESSORY
  BACKGROUND
}

model ShopItem {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  emoji       String
  category    ItemCategory
  price       Int
  minLevel    Int          @default(1)
  description String?
  rarity      String       @default("common")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())

  inventory UserInventory[]
}

model UserInventory {
  id         String   @id @default(cuid())
  userId     String
  itemId     String
  isEquipped Boolean  @default(false)
  acquiredAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId, isEquipped])
}

// =====================================================
// CHALLENGE
// =====================================================
model TeamChallenge {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
}

// =====================================================
// API KEYS
// =====================================================
model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  prefix     String
  hashedKey  String    @unique
  scopes     String    @default("read")
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@index([hashedKey])
}

// =====================================================
// PHISHING SIMULE
// =====================================================
enum PhishingTemplate {
  // Email phishing
  FAKE_MICROSOFT
  FAKE_COLISSIMO
  FAKE_PRESIDENT
  // SMS smishing
  SMS_FAKE_LIVREUR     // "Votre colis La Poste / Chronopost - frais de livraison"
  SMS_FAKE_BANQUE      // "Tentative de paiement detectee, validez via lien"
  SMS_FAKE_IMPOTS      // "Trop-percu ANTS / Service Public - IBAN a verifier"
  SMS_FAKE_2FA         // "Votre code 2FA est XXX, partagez-le si on vous demande"
  SMS_FAKE_PRESIDENT   // "Operation confidentielle, urgent, repondez"
}

enum PhishingChannel {
  EMAIL
  SMS
}

enum PhishingStatus {
  SENT
  CLICKED
  REPORTED
}

model PhishingCampaign {
  id          String           @id @default(cuid())
  tenantId    String
  title       String
  template    PhishingTemplate
  // Canal d'envoi : EMAIL (phishing classique) ou SMS (smishing).
  // Le contenu pedagogique change selon le canal.
  channel     PhishingChannel  @default(EMAIL)
  // Corps du SMS si channel=SMS (max 160 chars + lien tracke ajoute).
  // Pour le phishing email le corps est dans le template, pas ici.
  smsBody     String?
  scheduledAt DateTime
  sentAt      DateTime?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  results PhishingResult[]

  @@index([tenantId])
  @@index([tenantId, channel])
}

model PhishingResult {
  id         String         @id @default(cuid())
  campaignId String
  userId     String
  trackToken String         @unique
  status     PhishingStatus @default(SENT)
  sentAt     DateTime       @default(now())
  clickedAt  DateTime?
  reportedAt DateTime?

  campaign PhishingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([trackToken])
}

// =====================================================
// NOTIFICATIONS
// =====================================================
enum NotificationType {
  REMINDER_INACTIVE
  REMINDER_MANDATORY
  WELCOME
  CERTIFICATE_READY
}

model NotificationLog {
  id       String           @id @default(cuid())
  tenantId String
  userId   String
  type     NotificationType
  channel  String           @default("email")
  status   String           @default("sent")
  payload  Json?
  sentAt   DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, sentAt])
  @@index([userId, type])
}

// =====================================================
// MARKETPLACE - Modules communautaires
// SECURITE :
//  - payload validé par Zod cote serveur (pas de HTML, longueurs max)
//  - hash SHA-256 du payload publie => integrite verifiable
//  - moderation humaine obligatoire (PENDING_REVIEW -> APPROVED/REJECTED)
//  - audit log via Event
// =====================================================
enum MarketplaceStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  DEPRECATED
}

enum MarketplaceLicense {
  CC_BY      // Creative Commons - Attribution
  CC_BY_SA   // Creative Commons - Attribution + Partage dans les memes conditions
  PROPRIETARY // Reserve aux modules officiels HumaniX
}

model MarketplaceModule {
  id              String              @id @default(cuid())
  slug            String              @unique
  title           String
  description     String
  emoji           String              @default("🎯")
  category        String              // phishing / mdp / donnees / teletravail / fraude / reseaux / crise
  difficulty      String              @default("medium") // easy / medium / hard
  language        String              @default("fr")

  // Auteur
  authorId        String
  authorOrgName   String?             // Nom de l'organisation de l'auteur (optionnel)
  isOfficial      Boolean             @default(false) // true uniquement pour modules HumaniX

  // Versioning + integrite
  version         String              @default("1.0.0")
  contentHash     String              // SHA-256 du payload JSON normalise
  payload         Json                // Contenu structure (cf. lib/marketplace/schema.ts)

  // Moderation
  status          MarketplaceStatus   @default(DRAFT)
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewedById    String?
  rejectionReason String?

  // Legal
  license         MarketplaceLicense  @default(CC_BY_SA)

  // Stats
  installCount    Int                 @default(0)

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  author        User                       @relation("AuthoredModules", fields: [authorId], references: [id], onDelete: Cascade)
  reviewedBy    User?                      @relation("ReviewedModules", fields: [reviewedById], references: [id], onDelete: SetNull)
  installations MarketplaceInstallation[]
  saisons       Saison[]                   // Saisons clonees a partir de ce module

  @@index([status])
  @@index([category])
  @@index([authorId])
}

model MarketplaceInstallation {
  id           String   @id @default(cuid())
  tenantId     String
  moduleId     String
  saisonId     String?  // Saison clonee creee lors de l'installation
  installedAt  DateTime @default(now())
  installedById String  // userId de l'admin qui a installe
  isActive     Boolean  @default(true)

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module MarketplaceModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@index([tenantId])
}

// =====================================================
// LIBRAIRIE - Micro-learning (articles courts standalone)
// =====================================================
model LibraryArticle {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String
  emoji           String   @default("📖")
  category        String   // mfa / phishing / mots-de-passe / byod / grand-public / etc.
  audience        String   @default("pro") // pro / tous / famille - pour partage hors-pro
  readTimeMinutes Int      @default(5)
  body            String   @db.Text // Markdown safe-rendered (geres cote app, pas de HTML brut)
  authorName      String?
  isPublished     Boolean  @default(true)
  viewCount       Int      @default(0)
  shareCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([isPublished])
  @@index([audience])
}

// =====================================================
// MODULE POST-INCIDENT - Cyber-Reflexe
// Workflow guide de reponse a incident pour PME (RGPD art. 33 + NIS2 24h/72h).
// Chaque incident porte sa propre timeline d'actions a cocher + RetEx final.
// Reserve aux plans Pro+.
// =====================================================
enum IncidentType {
  RANSOMWARE       // Rançongiciel
  DATA_LEAK        // Fuite / vol de donnees
  PHISHING_VICTIM  // Compromission via phishing reussi
  FRAUDE_FINANCIERE // Fraude au president / faux fournisseur
  COMPTE_COMPROMIS // Prise de controle de compte (Microsoft 365, etc.)
  INTRUSION        // Intrusion systeme / serveur
  DDOS             // Deni de service
  AUTRE
}

enum IncidentSeverity {
  LOW              // Mineur (suspicion, contenu)
  MEDIUM           // Significatif (perimetre limite)
  HIGH             // Majeur (perimetre etendu)
  CRITICAL         // Critique (continuite menacee, donnees sensibles)
}

enum IncidentStatus {
  OPEN             // Vient d'etre cree
  IN_PROGRESS      // Reponse en cours
  CONTAINED        // Contenu (l'attaquant n'a plus acces)
  RESOLVED         // Resolu
  CLOSED           // Cloture (RetEx fait)
}

model IncidentResponse {
  id                 String           @id @default(cuid())
  tenantId           String
  // Identification
  reference          String           // Ex: "INC-2026-001" auto-genere
  title              String           // Resume court (ex: "Compromission email DSI")
  type               IncidentType
  severity           IncidentSeverity @default(MEDIUM)
  status             IncidentStatus   @default(OPEN)
  // Contexte
  detectedAt         DateTime         // Quand l'incident a ete detecte
  reportedById       String?          // userId de qui a leve l'alerte
  description        String           @db.Text
  affectedSystems    String?          @db.Text // Systemes / services touches
  affectedUsers      Int?             // Estimation nombre d'utilisateurs touches
  dataConcerned      String?          @db.Text // Categories de donnees concernees
  // Notifications obligatoires
  cnilNotified       Boolean          @default(false)
  cnilNotifiedAt     DateTime?
  cnilReference      String?          // Numero de telesignalement
  anssiNotified      Boolean          @default(false)
  anssiNotifiedAt    DateTime?
  anssiReference     String?
  // Resolution
  containedAt        DateTime?
  resolvedAt         DateTime?
  closedAt           DateTime?
  rootCause          String?          @db.Text // Cause racine identifiee
  retexNotes         String?          @db.Text // Lecons apprises
  // Stats
  estimatedCost      Int?             // Cout estime en euros
  // Meta
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actions            IncidentAction[]
  timeline           IncidentTimeline[]

  @@unique([tenantId, reference])
  @@index([tenantId, status])
  @@index([tenantId, detectedAt])
}

// Action a executer (issue d'une checklist) ou ajoutee manuellement
model IncidentAction {
  id           String          @id @default(cuid())
  incidentId   String
  // Categorisation
  phase        String          // h0 / h24 / h72 / w1 / retex
  category     String          // confinement / notification / communication / forensic / retex
  title        String
  description  String?         @db.Text
  // Etat
  isDone       Boolean         @default(false)
  doneAt       DateTime?
  doneById     String?
  // Ordre d'affichage
  position     Int             @default(0)
  // Lien vers un document genere (modele PDF/DOCX)
  documentSlug String?         // ex: "notification-cnil"

  incident     IncidentResponse @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, phase, position])
}

// Journal libre des evenements (decisions, communications, points cles)
model IncidentTimeline {
  id          String           @id @default(cuid())
  incidentId  String
  authorId    String?
  authorName  String?          // Snapshot du nom au moment de l'ecriture
  occurredAt  DateTime         @default(now())
  kind        String           @default("note") // note / decision / external_comm / discovery
  content     String           @db.Text
  createdAt   DateTime         @default(now())

  incident    IncidentResponse @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, occurredAt])
}

// =====================================================
// CYBER-ANECDOTE DU LUNDI - Newsletter hebdomadaire automatique
// Une anecdote par semaine envoyee a tous les abonnes (apprenants + leads
// publics inscrits via la home). Installe une habitude de vigilance cyber.
// =====================================================
enum AnecdoteCategory {
  RANSOMWARE        // Ransomware / extorsion
  PHISHING          // Phishing / social engineering
  FRAUDE            // Fraude au president, fraude bancaire
  DATA_LEAK         // Fuite de donnees / RGPD
  SUPPLY_CHAIN      // Chaine d'approvisionnement
  HACKTIVISME       // Defacement / hacktivisme
  IA_ABUS           // Abus IA / deepfake
  AUTRE
}

model WeeklyAnecdote {
  id            String           @id @default(cuid())
  slug          String           @unique
  title         String           // Ex: "Le CHU de Brest paralyse 3 semaines par un rancongiciel"
  // Le "punch" - 3 lignes max qui resument ce qu'il s'est passe
  summary       String           @db.Text
  // L'enseignement metier - la lecon a tirer en 1-2 phrases
  lesson        String           @db.Text
  // L'action concrete que le lecteur peut faire des aujourd'hui
  miniAction    String           @db.Text
  // Source presse / officielle
  sourceUrl     String
  sourceLabel   String           // Ex: "ZDNet, 15 mars 2026"
  category      AnecdoteCategory @default(AUTRE)
  // Date de l'incident reel (pour tri chronologique)
  incidentDate  DateTime
  // Programmation
  scheduledFor  DateTime?        // Lundi cible d'envoi
  publishedAt   DateTime?        // Date d'envoi effectif (null = brouillon)
  isActive      Boolean          @default(true)
  // Stats
  sentCount     Int              @default(0)
  openCount     Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([publishedAt])
  @@index([scheduledFor])
  @@index([category])
}

model AnecdoteSubscription {
  id               String   @id @default(cuid())
  email            String   @unique
  // Source d'inscription : "homepage", "audit-flash", "tenant" (auto user), "footer"
  source           String   @default("manual")
  // Si abonnement lie a un tenant client, on garde la trace pour reporting
  tenantId         String?
  // Token unique pour desinscription one-click (RGPD)
  unsubscribeToken String   @unique
  isActive         Boolean  @default(true)
  unsubscribedAt   DateTime?
  // Stats
  emailsReceived   Int      @default(0)
  lastSentAt       DateTime?
  // RGPD
  consentTextHash  String?  // Hash du texte de consentement au moment de l'inscription (preuve)
  ipHash           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
  @@index([tenantId])
}

// =====================================================
// AUDIT FLASH - Lead generation depuis le quiz public /audit-flash
// Pas de tenantId : ce sont des leads anonymes / pre-clients.
// =====================================================
enum AuditLeadStatus {
  NEW           // Vient d'etre soumis
  CONTACTED     // Email/RDV envoye
  QUALIFIED     // Lead qualifie (entreprise pertinente)
  CONVERTED     // Devenu client
  ARCHIVED      // Hors cible
}

model AuditFlashSubmission {
  id              String          @id @default(cuid())
  // Identite (declarative)
  email           String
  contactName     String?
  companyName     String
  size            String          // 1-9 / 10-49 / 50-249 / 250+
  sector          String          // services / industrie / commerce / sante / finance / public / associatif / autre
  // Resultat
  answers         Json            // { questionId: "yes" | "no" | "unsure" }
  score           Int             // 0-100
  verdictLabel    String          // Excellent / Solide / Fragile / À risque
  topRiskCats     String          // CSV des categories en top risques (ex: "humain,donnees,identite")
  recommendedPlan String          // solo / essentielle / pro / premium
  nis2Concerned   Boolean         @default(false)
  // CRM
  leadStatus      AuditLeadStatus @default(NEW)
  leadNotes       String?         @db.Text
  // RGPD
  consentMarketing Boolean        @default(false)
  // Meta
  ipHash          String?         // Hash SHA-256 de l'IP (anti-spam, RGPD-compatible)
  userAgent       String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([leadStatus])
  @@index([createdAt])
  @@index([email])
}

// =====================================================
// WEBHOOKS - Notifications sortantes Slack / Teams / generiques
// Chaque tenant peut configurer N webhooks. Les helpers fire dans
// lib/webhooks/* envoient des payloads adaptes au type cible.
// =====================================================
enum WebhookType {
  SLACK     // URL https://hooks.slack.com/services/...
  TEAMS     // URL Microsoft Teams Connector
  GENERIC   // POST JSON simple (Zapier, n8n, custom...)
}

model TenantWebhook {
  id          String      @id @default(cuid())
  tenantId    String
  label       String      // "Canal #cyber-team", "Webhook Zapier", etc.
  type        WebhookType
  url         String      @db.Text
  // Bitmask des evenements abonnes (cf. lib/webhooks/events.ts)
  events      String      // CSV : "phishing.completed,risk.degraded,episode.completed"
  // Secret pour signature HMAC (uniquement type GENERIC)
  secret      String?
  isActive    Boolean     @default(true)
  // Stats
  successCount Int        @default(0)
  failureCount Int        @default(0)
  lastFiredAt  DateTime?
  lastError    String?    @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
}

// =====================================================
// CYBER FAMILLE - Invitations virales offertes a 3 proches
// Quand un employe termine sa saison 1 il debloque 3 invitations
// vers sa famille (parents, conjoint, enfants). Chaque proche obtient
// un acces gratuit a /famille (articles publics) en se rappelant qu'il a
// ete invite par {sponsor} via {entreprise}. Boucle virale.
// =====================================================
enum FamilyInviteStatus {
  PENDING
  REDEEMED
  EXPIRED
  REVOKED
}

model FamilyInvite {
  id              String             @id @default(cuid())
  // Sponsor : l'employe du tenant qui offre l'invitation
  sponsorUserId   String
  sponsorTenantId String
  // Destinataire (declaratif - on demande juste un email)
  inviteeEmail    String
  inviteeFirstName String?
  // Token public unique pour activation par lien magique
  token           String             @unique
  status          FamilyInviteStatus @default(PENDING)
  // Tracking
  sentAt          DateTime           @default(now())
  redeemedAt      DateTime?
  redeemedIpHash  String?
  expiresAt       DateTime           // sentAt + 90j
  // Texte du message personnel ajoute par le sponsor (optionnel)
  personalMessage String?            @db.Text

  sponsor       User   @relation("FamilyInviteSponsor", fields: [sponsorUserId], references: [id], onDelete: Cascade)
  sponsorTenant Tenant @relation(fields: [sponsorTenantId], references: [id], onDelete: Cascade)

  @@index([sponsorUserId])
  @@index([sponsorTenantId])
  @@index([status])
  @@index([token])
}

// =====================================================
// EXPERT PROFILE - Bibliotheque vivante d'experts cyber francais
// Une personne (User) peut etre auteur de modules marketplace ET avoir
// un profil public expert valorisant sa contribution. C'est le levier
// communautaire qui rend la marketplace "vivante" (vs un catalogue genere
// en interne par les concurrents).
// =====================================================
model ExpertProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  // Identifiant public stable (pour /experts/:slug). Genere a la creation.
  slug            String   @unique
  // Bio publique (markdown safe-rendered cote app, pas de HTML brut)
  headline        String   // titre court : "RSSI - Cabinet Dupont", "Gendarme retraite"
  bio             String   @db.Text
  organization    String?  // Organisation actuelle (CHU, ANSSI, cabinet, etc.)
  // Reseaux pro (optionnel)
  linkedinUrl     String?
  websiteUrl      String?
  // Photo : URL d'avatar (uploaded ailleurs, on stocke juste le pointeur)
  avatarUrl       String?
  // Domaines d'expertise : CSV (ex: "phishing,iam,nis2,sante")
  expertiseTags   String   @default("")
  // Visibilite : un profil peut etre cache temporairement (ex: l'expert quitte)
  isPublished     Boolean  @default(true)
  // Distinctions (CSV) - libre. Ex: "ANSSI cert. RSSI", "OSCP", "20 ans terrain"
  credentials     String   @default("")
  // Stats : auto-calculees, denormalisees
  modulesCount    Int      @default(0)  // nb de modules APPROVED publies
  totalInstalls   Int      @default(0)  // somme des installations
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isPublished])
}

// =====================================================
// OBSERVATOIRE DES FUITES DE DONNEES
// Aggregation de 3 sources publiques francophones :
//  - frenchbreaches.com
//  - bonjourlafuite.eu.org
//  - fuitesinfos.fr
//
// Pas de tenantId : les fuites sont des INFOS PUBLIQUES, partagees a tous.
// Ne contient PAS de donnees fuitees, juste les metadonnees de l'incident
// (organisation victime, date, type de donnees, source). RGPD-safe.
// =====================================================
enum BreachSource {
  FRENCHBREACHES   // frenchbreaches.com
  BONJOURLAFUITE   // bonjourlafuite.eu.org
  FUITESINFOS      // fuitesinfos.fr
  MANUAL           // saisie manuelle SUPERADMIN
}

model DataBreach {
  id             String       @id @default(cuid())
  // Identifiant externe stable : utilise pour la dedup avec la source.
  // Soit un id natif scrape, soit un hash sha256(title + date) si pas d'id.
  externalId     String
  source         BreachSource
  // URL canonique de l'article source (pour citation)
  sourceUrl      String       @db.Text
  // Le titre tel que publie par la source
  title          String       @db.Text
  // Organisation victime (parsee best-effort depuis le titre)
  organization   String?
  // Pays principal de l'incident (FR par defaut pour ces 3 sources)
  country        String       @default("FR")
  // Secteur (sante / finance / education / public / etc.)
  sector         String?
  // Date de l'incident OU date de publication si incident inconnu
  incidentDate   DateTime
  // Date de scraping (pour debug)
  scrapedAt      DateTime     @default(now())
  // Resume court (max 500 chars)
  summary        String?      @db.Text
  // Nombre d'enregistrements exposes (null si non communique)
  recordsExposed Int?
  // Types de donnees fuitees (CSV : "email,nom,telephone,mdp")
  dataTypes      String?
  // Severity heuristique pour tri/affichage : "low" / "medium" / "high" / "critical"
  severity       String       @default("medium")
  // Visible dans l'observatoire public (false = caché par moderation)
  isPublished    Boolean      @default(true)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Dedup forte : meme externalId par source = meme fuite
  @@unique([source, externalId])
  @@index([incidentDate])
  @@index([source, incidentDate])
  @@index([isPublished, incidentDate])
}

// =====================================================
// AUDIT LOG - Journal de conformité
//
// Distinct du modèle Event (qui sert au business / gamification).
// AuditLog trace les actions sensibles pour la conformité RGPD (accountability
// art. 5.2), NIS2, ISO 27001 (A.12.4 Logging and monitoring), ANSSI.
//
// Principes :
//  - Append-only (jamais d'UPDATE / DELETE en code applicatif)
//  - Snapshot des identités (actorEmail, actorRole) pour résister à la
//    suppression d'un compte ultérieurement.
//  - IP hashée SHA-256 (RGPD-safe - réversible uniquement avec dictionnaire)
//  - Conservation : 13 mois minimum (recommandation CNIL pour les logs
//    sécurité, à aligner avec votre politique). Purge gérée par
//    scripts/purge-old-audit-logs.ts.
// =====================================================
enum AuditAction {
  // Authentification
  USER_LOGIN_SUCCESS
  USER_LOGIN_FAILED
  USER_LOGOUT
  USER_LOCKED
  USER_UNLOCKED
  USER_PASSWORD_CHANGED
  USER_PASSWORD_RESET_REQUESTED
  USER_PASSWORD_RESET_USED
  USER_MFA_ENABLED
  USER_MFA_DISABLED
  USER_MFA_FORCED
  USER_MFA_RESET_BY_ADMIN
  USER_WEBAUTHN_REGISTERED
  USER_WEBAUTHN_DELETED
  USER_WEBAUTHN_LOGIN
  // Lifecycle utilisateur
  USER_INVITED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_ACTIVATED
  USER_SUSPENDED
  USER_ROLE_CHANGED
  USER_GROUPS_CHANGED
  // Tenant
  TENANT_CREATED
  TENANT_UPDATED
  TENANT_DELETED
  // Groupes
  GROUP_CREATED
  GROUP_UPDATED
  GROUP_DELETED
  // Billing
  BILLING_CHECKOUT_STARTED
  BILLING_SUBSCRIPTION_CREATED
  BILLING_SUBSCRIPTION_UPDATED
  BILLING_SUBSCRIPTION_CANCELED
  BILLING_PAYMENT_FAILED
  BILLING_PORTAL_ACCESSED
  // RGPD - Droits des personnes
  DATA_ACCESSED          // art. 15 - l'user consulte ses donnees
  DATA_EXPORTED          // art. 20 - portabilite (download JSON)
  DATA_ERASURE_REQUESTED // art. 17 - demande d'effacement
  DATA_ERASURE_COMPLETED // art. 17 - effacement effectue
  CONSENT_GIVEN
  CONSENT_WITHDRAWN
  // Securite / divers
  API_KEY_CREATED
  API_KEY_REVOKED
  EVIDENCE_BUNDLE_EXPORTED
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  DENIED      // refus d'autorisation (forbidden)
}

enum AuditSeverity {
  INFO
  NOTICE
  WARNING
  CRITICAL
}

model AuditLog {
  id          String        @id @default(cuid())
  tenantId    String?       // null pour les actions cross-tenant SUPERADMIN
  // Acteur - snapshot pour resister a la suppression
  actorUserId String?       // null si systeme / pre-auth (ex: login failed)
  actorEmail  String?       // snapshot au moment du log
  actorRole   String?       // snapshot
  // Action
  action      AuditAction
  outcome     AuditOutcome
  severity    AuditSeverity @default(INFO)
  // Cible (optionnelle)
  targetType  String?       // "user", "tenant", "group", "subscription", ...
  targetId    String?
  targetLabel String?       // snapshot lisible (email, nom, slug)
  // Contexte technique
  ipHash      String?       // SHA-256 hex (RGPD-safe)
  userAgent   String?       @db.Text
  message     String?       @db.Text
  metadata    Json?

  createdAt   DateTime      @default(now())

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([severity, createdAt])
}

// =====================================================
// EVENEMENTS
// =====================================================
model Event {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  type      String
  payload   Json
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([type])
}
