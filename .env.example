# =============================================================================
# Humanix Académie · Community Edition — variables d'environnement
# =============================================================================
#
# Copie ce fichier en .env (ou .env.local en dev) et renseigne tes valeurs.
# Le fichier .env est gitignored — il ne sera JAMAIS commité.
#
# Documentation complète : docs/configuration.md
#
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIS — Sans ces 5 variables, l'application refuse de démarrer.
# -----------------------------------------------------------------------------

# URL de connexion PostgreSQL.
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# En production : ajoute &sslmode=require pour les bases managées.
DATABASE_URL="postgresql://humanix:CHANGE_ME@postgres:5432/humanix?schema=public"

# Secret de signature des sessions NextAuth. 32+ caractères aléatoires.
# Génère avec : openssl rand -base64 32
# JAMAIS commiter en git. Régénérer = invalider toutes les sessions.
AUTH_SECRET="REMPLACE_MOI_PAR_UN_SECRET_GENERE_AVEC_OPENSSL_RAND_BASE64_32"

# URL publique canonique (pour redirections OAuth, magic links, exports PDF).
AUTH_URL="https://academie.tonentreprise.fr"

# URL publique côté client (doit correspondre à AUTH_URL).
NEXT_PUBLIC_APP_URL="https://academie.tonentreprise.fr"

# Nom affiché dans les onglets, emails, footer.
NEXT_PUBLIC_APP_NAME="Humanix Académie"

# -----------------------------------------------------------------------------
# FORTEMENT RECOMMANDÉ — sans email transactionnel, magic links cassés.
# -----------------------------------------------------------------------------

# Clé API Resend (https://resend.com) pour les emails transactionnels.
# Alternative : adapter lib/email.ts pour SMTP / SendGrid / Mailgun.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"

# Adresse expéditeur. Domaine doit être vérifié dans Resend (SPF + DKIM).
EMAIL_FROM="noreply@academie.tonentreprise.fr"

# -----------------------------------------------------------------------------
# MODES SPÉCIAUX
# -----------------------------------------------------------------------------

# Mode démo : connexion 1-clic via /demo, pas de magic link envoyé.
# À NE JAMAIS activer en production avec de vraies données utilisateurs.
DEMO_MODE="false"

# Mode démo publique (Sprint 4 — pour demo.humanix.fr uniquement).
# Bypass auth + auto-login par rôle. Désactivé par défaut.
DEMO_PUBLIC="false"

# Environnement Node.js (production | development | test).
NODE_ENV="production"

# -----------------------------------------------------------------------------
# FEATURES IA SOUVERAINES (palier Pro+)
# -----------------------------------------------------------------------------

# Clé API Mistral AI (https://console.mistral.ai) pour :
# - Phishing personnalisé par employé
# - IA Coach Hex
# - Génération d'anecdotes cyber
MISTRAL_API_KEY=""
MISTRAL_MODEL="mistral-large-latest"

# -----------------------------------------------------------------------------
# SSO entreprise (palier Essentielle+)
# -----------------------------------------------------------------------------

# Microsoft 365 / Entra ID
# Configuration : Azure Portal → App registrations → New registration
AUTH_MICROSOFT_ENTRA_ID=""
AUTH_MICROSOFT_ENTRA_SECRET=""
AUTH_MICROSOFT_ENTRA_TENANT_ID=""

# Google Workspace
# Configuration : https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# -----------------------------------------------------------------------------
# OBSERVABILITÉ (optionnel mais recommandé en prod)
# -----------------------------------------------------------------------------

# Sentry — error tracking.
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"

# Plausible Analytics (RGPD-friendly, idéal en self-hosted).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_PLAUSIBLE_API_HOST=""

# OpenTelemetry (traces).
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_SERVICE_NAME="humanix-academie"

# -----------------------------------------------------------------------------
# STORAGE S3 (uploads modules contributeurs, palier Pro+)
# -----------------------------------------------------------------------------

# Compatible : Scaleway Object Storage, OVHcloud, AWS S3, MinIO, Cloudflare R2.
S3_ENDPOINT=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_PUBLIC_URL=""

# -----------------------------------------------------------------------------
# TTS — Text-to-Speech (palier Pro+)
# -----------------------------------------------------------------------------

# Provider : azure | google | elevenlabs | local
TTS_PROVIDER=""
TTS_API_KEY=""
TTS_REGION=""
TTS_MIN_PLAN="pro"

# -----------------------------------------------------------------------------
# WEBHOOKS sortants (palier Essentielle+)
# -----------------------------------------------------------------------------

# Secret de signature HMAC-SHA256 des webhooks. 32+ caractères.
# Génère avec : openssl rand -base64 32
WEBHOOK_SECRET=""

WEBHOOK_TIMEOUT_MS="5000"
WEBHOOK_MAX_RETRIES="3"

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

# Limite globale par IP par minute.
RATE_LIMIT_PER_MINUTE="120"

# Limite spécifique aux endpoints d'auth (anti-brute-force).
RATE_LIMIT_AUTH_PER_MINUTE="10"

# -----------------------------------------------------------------------------
# DEBUG / DÉVELOPPEMENT
# -----------------------------------------------------------------------------

# Niveau de log Prisma. NE JAMAIS mettre "query" en prod.
PRISMA_LOG_LEVEL="info"

# Niveau de log applicatif (debug | info | warn | error).
LOG_LEVEL="info"
