# =============================================================================
# Humanix Académie · Community Edition — variables d'environnement
# =============================================================================
#
# Copie ce fichier en .env (ou .env.local en dev) et renseigne tes valeurs.
# Le fichier .env est gitignored — il ne sera JAMAIS commité.
#
# Documentation complète : docs/configuration.md
#
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIS — Sans ces 5 variables, l'application refuse de démarrer.
# -----------------------------------------------------------------------------

# URL de connexion PostgreSQL.
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# En production : ajoute &sslmode=require pour les bases managées.
DATABASE_URL="postgresql://humanix:CHANGE_ME@postgres:5432/humanix?schema=public"

# Secret de signature des sessions NextAuth. 32+ caractères aléatoires.
# Génère avec : openssl rand -base64 32
# JAMAIS commiter en git. Régénérer = invalider toutes les sessions.
AUTH_SECRET="REMPLACE_MOI_PAR_UN_SECRET_GENERE_AVEC_OPENSSL_RAND_BASE64_32"

# URL publique canonique (pour redirections OAuth, magic links, exports PDF).
AUTH_URL="https://academie.tonentreprise.fr"

# URL publique côté client (doit correspondre à AUTH_URL).
NEXT_PUBLIC_APP_URL="https://academie.tonentreprise.fr"

# Nom affiché dans les onglets, emails, footer.
NEXT_PUBLIC_APP_NAME="Humanix Académie"

# -----------------------------------------------------------------------------
# FORTEMENT RECOMMANDÉ — sans email transactionnel, magic links cassés.
# Provider : Scaleway Transactional Email (TEM), souverain français (Paris).
# -----------------------------------------------------------------------------
#
# Configuration :
#  1. Console Scaleway > Transactional Email > activer le service
#  2. Vérifier le domaine d'envoi (SPF + DKIM + DMARC)
#  3. IAM > créer une clé API avec scope TransactionalEmailEmailFullAccess
#     /!\ Le secret-key n'est affiché QU'UNE SEULE FOIS à la création.
#     Le sauvegarder. Si perdu, recréer une clé.
#  4. Récupérer le project ID Scaleway (UUID dans Project settings)

# SECRET-KEY de la clé IAM Scaleway. Format : UUID 36 caractères avec tirets,
# ex : 3d09812a-xxxx-xxxx-xxxx-076d0a8b1c2e
#
# /!\ ATTENTION : ne PAS confondre avec l'access-key (qui commence par "SCW"
# et fait 20 caracteres). L'access-key sert au SDK Scaleway officiel mais
# PAS a l'API REST TEM. Pour TEM, c'est uniquement le secret-key (UUID) qui
# est envoye dans le header X-Auth-Token.
#
# Si ton token commence par SCW... ou fait 20 caracteres -> c'est faux,
# tu as colle l'access-key. L'API renverra 401 denied_authentication.
SCALEWAY_TEM_TOKEN=""

# UUID du projet Scaleway dans lequel TEM est activé.
# Format : UUID 36 caracteres, ex : c9a236c0-86de-4360-9a19-21e04705c7f6
# Console Scaleway > Project settings > Project ID
SCALEWAY_TEM_PROJECT_ID=""

# Région Scaleway. Défaut : fr-par (Paris). Autres : nl-ams (Amsterdam),
# pl-waw (Varsovie). Choisir Paris pour rester strictement souverain FR.
SCALEWAY_TEM_REGION="fr-par"

# Adresse expéditeur. Domaine doit être vérifié dans Scaleway TEM
# (SPF + DKIM + DMARC validés via la console Scaleway).
EMAIL_FROM="noreply@academie.tonentreprise.fr"

# -----------------------------------------------------------------------------
# MODES SPÉCIAUX
# -----------------------------------------------------------------------------

# Mode démo : connexion 1-clic via /demo, pas de magic link envoyé.
# À NE JAMAIS activer en production avec de vraies données utilisateurs.
DEMO_MODE="false"

# Mode dev : bypass des intégrations externes pour tester les flows réels
# d'inscription/souscription en local sans configurer Payplug ni Scaleway TEM.
#   - /inscription : pas d'email envoyé, auto-login direct comme si on
#     avait cliqué sur le magic link (provider Credentials "dev-bypass").
#   - /souscrire : pas d'appel Payplug, le tenant et l'admin sont créés
#     directement et l'utilisateur est connecté sur /admin.
#
# IGNORÉ AUTOMATIQUEMENT EN PRODUCTION (NODE_ENV=production) — garde-fou
# critique pour empêcher l'auto-création d'ADMIN sur n'importe quel tenant.
DEV_MODE="false"

# -----------------------------------------------------------------------------
# BOOTSTRAP DU PREMIER ADMINISTRATEUR
# -----------------------------------------------------------------------------
# Le système refuse les inscriptions ouvertes par design (les comptes doivent
# être pré-créés par un admin). Sur une base vierge, ces variables permettent
# de créer automatiquement le tout-premier administrateur au démarrage.
# Une fois qu'un admin existe en base, ces variables sont ignorées.
#
# Sans ces variables, vous devrez seeder manuellement un admin via :
#   docker compose exec app npx tsx scripts/bootstrap-admin.ts
#
# Recommandation : laissez BOOTSTRAP_ADMIN_PASSWORD vide en production et
# utilisez le magic link à la première connexion (plus sûr qu'un mdp en env).

# Email du premier admin. Si vide : pas de bootstrap, base reste vierge.
BOOTSTRAP_ADMIN_EMAIL=""

# Mot de passe initial (optionnel). Si vide : connexion par magic link uniquement.
# Min 10 caractères, 3 classes parmi maj/min/chiffre/symbole.
BOOTSTRAP_ADMIN_PASSWORD=""

# Identité du premier admin et de son organisation (tous optionnels).
BOOTSTRAP_ADMIN_NAME="Administrateur"
BOOTSTRAP_TENANT_NAME="Mon organisation"
BOOTSTRAP_TENANT_SLUG="default"

# Mode démo publique (Sprint 4 — pour demo.humanix.fr uniquement).
# Bypass auth + auto-login par rôle. Désactivé par défaut.
DEMO_PUBLIC="false"

# Environnement Node.js (production | development | test).
NODE_ENV="production"

# -----------------------------------------------------------------------------
# FEATURES IA SOUVERAINES (palier Pro+)
# -----------------------------------------------------------------------------

# Clé API Mistral AI (https://console.mistral.ai) pour :
# - Phishing personnalisé par employé
# - IA Coach Hex
# - Génération d'anecdotes cyber
MISTRAL_API_KEY=""
MISTRAL_MODEL="mistral-large-latest"

# -----------------------------------------------------------------------------
# SSO entreprise (palier Essentielle+)
# -----------------------------------------------------------------------------

# Microsoft 365 / Entra ID
# Configuration : Azure Portal → App registrations → New registration
AUTH_MICROSOFT_ENTRA_ID=""
AUTH_MICROSOFT_ENTRA_SECRET=""
AUTH_MICROSOFT_ENTRA_TENANT_ID=""

# Google Workspace
# Configuration : https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Apple "Sign in with Apple"
# Configuration : Apple Developer → Identifiers → Services ID + Key.
# AUTH_APPLE_SECRET est un JWT signé ES256 à régénérer périodiquement
# (validité max 6 mois côté Apple). Cf. https://authjs.dev/getting-started/providers/apple
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# -----------------------------------------------------------------------------
# OBSERVABILITÉ (optionnel mais recommandé en prod)
# -----------------------------------------------------------------------------

# Sentry — error tracking.
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"

# Plausible Analytics (RGPD-friendly, self-host AGPL).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_PLAUSIBLE_API_HOST=""

# Matomo Analytics (origine francaise, RGPD-strict, self-host GPL).
# Recommande pour le narratif souverain FR. Si rempli, le composant
# <MatomoScript /> inject le tracker dans le layout.
# Doc setup : 01_Infrastructure_Deploiement/07ter_analytics-matomo-beszel.md
NEXT_PUBLIC_MATOMO_URL=""
NEXT_PUBLIC_MATOMO_SITE_ID=""

# OpenTelemetry (traces).
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_SERVICE_NAME="humanix-academie"

# -----------------------------------------------------------------------------
# STORAGE S3 (uploads modules contributeurs, palier Pro+)
# -----------------------------------------------------------------------------

# Compatible : Scaleway Object Storage, OVHcloud, AWS S3, MinIO, Cloudflare R2.
S3_ENDPOINT=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_PUBLIC_URL=""

# -----------------------------------------------------------------------------
# TTS — Text-to-Speech (palier Pro+)
# -----------------------------------------------------------------------------
# Deux providers au choix :
#
#   1. "voxtral" (recommande prod)
#      Mistral Voxtral SaaS, voix Marie expressive, ~$0.0001/mot.
#      Necessite MISTRAL_API_KEY (deja defini plus haut).
#      Pre-rendu :  npm run tts:build  (cache MP3 ~80 Mo pour 662 segments)
#
#   2. "piper" (option self-host AGPL)
#      Container Piper local, voix fr_FR-siwis-medium, gratuit, RGPD-friendly.
#      Necessite : docker compose --profile piper up -d
#                  + TTS_SERVER_URL="http://tts:5500"
#      Pas de batch -- le runtime synthetise au fil des clics (CPU local, ~300 ms).
#
#   3. "" (vide = defaut)
#      Pas de TTS premium serveur. Le composant TTSButton bascule automatiquement
#      sur Web Speech API navigateur (gratuit, hors-ligne). UX dependante du browser.
#
# Si TTS_PROVIDER est vide mais MISTRAL_API_KEY existe, le mode "voxtral" est
# utilise par defaut (back-compat).

TTS_PROVIDER=""
TTS_SERVER_URL=""

# Plan minimum requis pour beneficier du TTS premium serveur.
# trial / solo / essentielle / pro / premium. Defaut : "pro".
TTS_MIN_PLAN="pro"

# Variables historiques pour fournisseurs externes (ignorees actuellement,
# placeholder pour une future integration Azure/Google/ElevenLabs).
TTS_API_KEY=""
TTS_REGION=""

# -----------------------------------------------------------------------------
# WEBHOOKS sortants (palier Essentielle+)
# -----------------------------------------------------------------------------

# Secret de signature HMAC-SHA256 des webhooks. 32+ caractères.
# Génère avec : openssl rand -base64 32
WEBHOOK_SECRET=""

WEBHOOK_TIMEOUT_MS="5000"
WEBHOOK_MAX_RETRIES="3"

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

# Limite globale par IP par minute.
RATE_LIMIT_PER_MINUTE="120"

# Limite spécifique aux endpoints d'auth (anti-brute-force).
RATE_LIMIT_AUTH_PER_MINUTE="10"

# -----------------------------------------------------------------------------
# LICENCE SIGNEE Humanix Cybersecurity (optionnel — self-host commercial)
# -----------------------------------------------------------------------------
#
# Si tu as souscrit a un plan Pro/Premium chez Humanix Cybersecurity et que
# tu choisis le self-host (au lieu du cloud), tu recevras une licence Ed25519
# signee qui debloque les features payantes (vishing, phishing IA, marketplace,
# Pack NIS2 turnkey, multi-etablissements, white-label, etc.).
#
# Format : "HUMANIX-LICENSE-v1.<base64>.<signature>"
# Cluster-locked au domaine si la licence le specifie.
#
# Pour tester en local sans licence : laisser vide. Le runtime fallback sur
# le plan DB du tenant (typiquement decouverte / trial). Toutes les features
# de base restent disponibles.
#
# Pour generer une licence (cote Humanix Cybersecurity uniquement) :
#   npm run licensing:generate -- --tenant="..." --plan=pro --years=1
#
# Documentation : docs/LICENSE_KEY.md

HUMANIX_LICENSE_KEY=""

# Override de la cle publique de verification (rare).
# Par defaut, on utilise PUBLIC_KEY_PEM hardcoded dans lib/license/public-key.ts.
# Cette variable permet de pointer vers une PKI alternative (forks self-host,
# tests, dual-licensing). L'AGPLv3 le permet — c'est meme l'esprit.
HUMANIX_LICENSE_PUBLIC_KEY=""

# -----------------------------------------------------------------------------
# SSO MICROSOFT 365 / ENTRA ID (optionnel)
# -----------------------------------------------------------------------------
#
# Si les 3 variables ci-dessous sont définies, le bouton "Continuer avec
# Microsoft" s'affiche sur /connexion. Sinon il est masqué proprement.
#
# Documentation : https://learn.microsoft.com/azure/active-directory/develop/v2-overview
# Configuration côté Azure :
#   1. Azure portal → Microsoft Entra ID → App registrations → New registration
#   2. Redirect URI : https://votre-domaine/api/auth/callback/microsoft-entra-id
#   3. Certificates & secrets → New client secret (durée recommandée : 24 mois)
#   4. API permissions : openid, profile, email (déjà dans User.Read)

AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
# Issuer = https://login.microsoftonline.com/<tenant-id>/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER=""

# -----------------------------------------------------------------------------
# CRON SECURISES (jobs internes)
# -----------------------------------------------------------------------------
#
# Secret partagé pour authentifier les jobs cron qui appellent les endpoints
# /api/cron/* et /api/admin/send-reminders. Sans ce secret, les endpoints
# refusent les déclenchements externes.
#
# Génère avec : openssl rand -base64 32
# Exemple d'appel : curl -H "x-cron-secret: $CRON_SECRET" https://.../api/cron/breaches-refresh

CRON_SECRET=""

# -----------------------------------------------------------------------------
# URL PUBLIQUE (alias historique pour SCIM/evidence-export)
# -----------------------------------------------------------------------------
#
# Le code utilise majoritairement NEXT_PUBLIC_APP_URL (ci-dessus), mais les
# routes SCIM v2 et /api/v1/evidence-export utilisent encore NEXT_PUBLIC_BASE_URL.
# Renseigne la même valeur que NEXT_PUBLIC_APP_URL pour que tout fonctionne.
# Dette technique : harmoniser sur NEXT_PUBLIC_APP_URL post-launch.

NEXT_PUBLIC_BASE_URL="https://academie.tonentreprise.fr"

# -----------------------------------------------------------------------------
# DEBUG / DÉVELOPPEMENT
# -----------------------------------------------------------------------------

# Niveau de log Prisma. NE JAMAIS mettre "query" en prod.
PRISMA_LOG_LEVEL="info"

# Niveau de log applicatif (debug | info | warn | error).
LOG_LEVEL="info"

# -----------------------------------------------------------------------------
# PAYPLUG — Facturation des plans payants (Solo / Essentielle / Pro)
# Prestataire de paiement souverain français (Natixis / Groupe BPCE).
# -----------------------------------------------------------------------------
# Si PAYPLUG_SECRET_KEY est vide, le checkout est désactivé. Les CTAs /tarifs
# redirigent vers /signup (création tenant trial), et le portail
# /profil/facturation affiche "module non configuré".
#
# Configuration :
#  1. Créer un compte Payplug Business : https://www.payplug.com/
#  2. Récupérer la clé secrète : Espace Payplug → Mon compte → API
#     Format : sk_test_… (test) ou sk_live_… (production).
#  3. Créer les Subscription Plans dans le dashboard Payplug pour Solo /
#     Essentielle / Pro et coller leurs IDs ci-dessous.
#  4. Configurer le webhook côté dashboard Payplug :
#     - URL : https://academie.tonentreprise.fr/api/payments/webhook
#     - Events : subscription.* + payment.*
#  5. Coller le webhook secret dans PAYPLUG_WEBHOOK_SECRET

# Clé secrète Payplug (server-only, JAMAIS exposée au client).
PAYPLUG_SECRET_KEY=""

# Secret de signature des webhooks (HMAC-SHA256 sur le body brut).
PAYPLUG_WEBHOOK_SECRET=""

# IDs des Subscription Plans Payplug par tier (vides = plan absent du
# checkout self-service). Premium reste typiquement sur devis.
# IDs de plan Payplug pour les 2 paliers cloud achetables self-service.
# Enterprise est exclu : process commercial manuel.
# Format : "plan_xxx" (UUID Payplug, recupere depuis le dashboard Payplug
# > Subscriptions > Plans).
PAYPLUG_PLAN_STARTER=""
PAYPLUG_PLAN_PRO=""

# -----------------------------------------------------------------------------
# WEBAUTHN — clés de sécurité FIDO2 pour SUPERADMIN
# -----------------------------------------------------------------------------
# WEBAUTHN_RP_ID (optionnel) : domaine "Relying Party" pour les credentials.
# Si vide, derive de AUTH_URL. À renseigner uniquement pour overrider, par ex.
# si l'app est sur app.example.com mais que tu veux les passkeys partageables
# avec example.com → mettre WEBAUTHN_RP_ID="example.com".
WEBAUTHN_RP_ID=""

# -----------------------------------------------------------------------------
# Note sur HUMANIX_API_KEY / HUMANIX_BASE_URL
# -----------------------------------------------------------------------------
#
# Ces deux variables ne sont PAS lues par l'application Humanix elle-même.
# Elles sont uniquement utilisées par les CONNECTEURS externes (MCP server,
# bridge CISO Assistant, etc.) qui interrogent l'API REST publique d'Humanix
# en tant que clients tiers.
#
# Si tu déploies un connecteur, configure-les dans le .env du connecteur, pas
# ici. Cf. connectors/mcp-server/.env.sample par exemple.
