{
  "name": "humanix-academie",
  "version": "1.2.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "description": "Humanix Académie Community Edition — plateforme française open source de cybersensibilisation pour PME.",
  "homepage": "https://humanix-cybersecurity.fr",
  "repository": {
    "type": "git",
    "url": "https://github.com/humanix-cybersecurity/humanix-academie.git"
  },
  "bugs": {
    "url": "https://github.com/humanix-cybersecurity/humanix-academie/issues"
  },
  "author": "Humanix Cybersecurity <contact@humanix-cybersecurity.fr>",
  "keywords": [
    "cybersecurity",
    "awareness",
    "phishing-simulation",
    "gamification",
    "pme",
    "souverain",
    "rgpd",
    "nis2",
    "agpl"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "tsc --noEmit && tsx scripts/lint-routes.ts",
    "lint:eslint": "eslint .",
    "lint:routes": "tsx scripts/lint-routes.ts",
    "typecheck": "tsc --noEmit",
    "hooks:install": "git config core.hooksPath .githooks",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate:mdx": "tsx scripts/validate-mdx-catalog.ts",
    "validate:mdx:strict": "tsx scripts/validate-mdx-catalog.ts --strict",
    "tts:build": "tsx scripts/tts-cache-build.ts",
    "tts:build:dry": "tsx scripts/tts-cache-build.ts --dry",
    "tts:build:force": "tsx scripts/tts-cache-build.ts --force",
    "tts:prune": "tsx scripts/tts-cache-prune.ts",
    "tts:prune:apply": "tsx scripts/tts-cache-prune.ts --apply",
    "hex:reindex": "tsx scripts/hex-reindex.ts",
    "hex:reindex:dry": "tsx scripts/hex-reindex.ts --dry",
    "audit:env": "tsx scripts/audit-env-coverage.ts",
    "license:headers": "tsx scripts/add-license-headers.ts",
    "license:check": "tsx scripts/add-license-headers.ts --check",
    "licensing:keygen": "tsx scripts/license-tool.ts keygen",
    "licensing:generate": "tsx scripts/license-tool.ts generate",
    "licensing:inspect": "tsx scripts/license-tool.ts inspect",
    "licensing:verify": "tsx scripts/license-tool.ts verify",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:bootstrap-admin": "tsx scripts/bootstrap-admin.ts",
    "db:reset": "prisma db push --force-reset --accept-data-loss && npm run db:seed",
    "db:purge-demo": "tsx scripts/purge-demo-fixtures.ts",
    "db:purge-demo:apply": "tsx scripts/purge-demo-fixtures.ts --apply",
    "db:wipe-content": "tsx scripts/wipe-content.ts",
    "db:wipe-content:apply": "tsx scripts/wipe-content.ts --apply",
    "breaches:refresh": "tsx scripts/scrape-breaches.ts",
    "breaches:refresh:deep": "tsx scripts/scrape-breaches.ts --deep",
    "breaches:debug": "tsx scripts/debug-breaches.ts",
    "breaches:cleanup": "tsx scripts/cleanup-breaches.ts",
    "postinstall": "prisma generate",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up --build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@fontsource-variable/inter": "^5.1.1",
    "@fontsource/atkinson-hyperlegible": "^5.1.1",
    "@mollie/api-client": "^4.5.0",
    "@prisma/client": "^6.16.0",
    "@react-pdf/renderer": "^4.1.5",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "canvas-confetti": "^1.9.3",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "isomorphic-dompurify": "^3.14.0",
    "next": "^16.2.6",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "^8.0.8",
    "papaparse": "^5.4.1",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/canvas-confetti": "^1.6.4",
    "@types/node": "^22.19.19",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "prettier": "^3.3.3",
    "prisma": "^6.16.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.10"
    },
    "esbuild": "^0.25.0",
    "vite": "^6.4.2"
  }
}
