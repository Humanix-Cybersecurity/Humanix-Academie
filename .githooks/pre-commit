#!/bin/sh
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Pre-commit hook : typecheck TypeScript avant chaque commit.
#
# Pourquoi : les erreurs TS qui passaient en local etaient remontees par le
# build Docker prod (~50s par cycle). Cet appel direct a `tsc --noEmit`
# tourne en 3-5s, attrape la meme classe de bugs et evite les rebuilds
# inutiles.
#
# Activation (a faire une fois par clone) :
#   npm run hooks:install
# (qui execute : git config core.hooksPath .githooks)
#
# Bypass ponctuel : git commit --no-verify

set -e

# Skip si aucun fichier TS/TSX dans le staging - le type graph n'a pas bouge.
# diff-filter=ACMR : ajoutes / copies / modifies / renommes
if ! git diff --cached --name-only --diff-filter=ACMR | grep -qE '\.(ts|tsx)$'; then
  exit 0
fi

# Skip avec warning si node_modules absent (fresh clone pas encore installe).
# Le commit reste autorise pour ne pas bloquer un dev qui n'a pas encore
# `npm install`.
if [ ! -x "node_modules/.bin/tsc" ]; then
  echo "[pre-commit] node_modules absent, typecheck skip (lance 'npm install' puis recommit)"
  exit 0
fi

START=$(date +%s)
echo "[pre-commit] tsc --noEmit..."

if ! node_modules/.bin/tsc --noEmit; then
  echo ""
  echo "[pre-commit] ECHEC : corrige les erreurs ci-dessus avant de committer."
  echo "[pre-commit] Pour bypass exceptionnel : git commit --no-verify"
  exit 1
fi

ELAPSED=$(( $(date +%s) - START ))
echo "[pre-commit] OK en ${ELAPSED}s"
