# humanix-glpi-bridge

# --- Humanix webhook secret (configuré côté admin Humanix) ---
HUMANIX_WEBHOOK_SECRET=REPLACE_ME

# --- GLPI 10.x (ITSM open-source 🇫🇷) ---
# Setup → General → API → activer + générer App-Token
GLPI_BASE_URL=https://glpi.exemple.fr
GLPI_APP_TOKEN=REPLACE_ME
# User technique → Préférences → Tokens d'API → générer User-Token
GLPI_USER_TOKEN=REPLACE_ME
# ID de l'entité GLPI dans laquelle créer les tickets (0 = root)
GLPI_ENTITY_ID=0

# --- Serveur HTTP ---
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
