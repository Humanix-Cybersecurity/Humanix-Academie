# Variables d'environnement pour humanix-ciso-connector
# cp .env.sample .env, puis renseigner les valeurs reelles.

# --- Humanix Academie ---
HUMANIX_BASE_URL=https://academie.humanix-cybersecurity.fr
# Cle API generee depuis /admin/api-keys (plan Essentielle ou superieur)
HUMANIX_API_KEY=hxa_REPLACE_ME

# --- CISO Assistant ---
CISO_BASE_URL=https://ciso.exemple.fr
CISO_USERNAME=connector@exemple.fr
CISO_PASSWORD=REPLACE_ME

# --- Logging ---
LOG_LEVEL=INFO
