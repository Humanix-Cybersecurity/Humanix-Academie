# Variables d'environnement pour humanix-sentinel-connector

# --- Humanix Académie ---
HUMANIX_BASE_URL=https://academie.humanix-cybersecurity.fr
HUMANIX_API_KEY=hxa_REPLACE_ME

# --- Azure AD App Registration (Service Principal) ---
# Rôle requis : 'Monitoring Metrics Publisher' sur la Data Collection Rule
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=REPLACE_ME

# --- Data Collection Endpoint + Rule ---
# Trouvable dans Azure Portal > Data Collection Endpoints > Overview
AZURE_DCE_URL=https://your-dce-xxx.francecentral-1.ingest.monitor.azure.com
# Immutable ID de la Data Collection Rule (Properties)
AZURE_DCR_IMMUTABLE_ID=dcr-00000000000000000000000000000000
# Nom du stream custom configuré dans la DCR
AZURE_STREAM_NAME=Custom-HumanixCompliance_CL

# --- Logging ---
LOG_LEVEL=INFO
