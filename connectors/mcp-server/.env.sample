# Configuration humanix-mcp-server
#
# Copie ce fichier vers .env (ne JAMAIS commiter .env) et remplis les valeurs.
# Pour Claude Desktop, mettre ces valeurs dans la section "env" de
# claude_desktop_config.json a la place de fichier .env.

# Cle API Humanix (obligatoire). Generer dans /admin/api-keys.
HUMANIX_API_KEY=hk_replace_me_with_real_key

# URL de votre instance Humanix Academie.
# Pour la version cloud SaaS : https://votre-tenant.humanix-cybersecurity.fr
# Pour self-host : https://academie.votre-domaine.fr
HUMANIX_BASE_URL=https://app.humanix-cybersecurity.fr
