# Variables d'environnement pour humanix-splunk-connector
# cp .env.sample .env, puis renseigner les valeurs.

# --- Humanix Académie ---
HUMANIX_BASE_URL=https://academie.humanix-cybersecurity.fr
HUMANIX_API_KEY=hxa_REPLACE_ME

# --- Splunk HEC ---
# Trouvez votre URL HEC dans : Settings → Data inputs → HTTP Event Collector
SPLUNK_HEC_URL=https://splunk.exemple.fr:8088
SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000000

# Désactiver la validation TLS uniquement en dev/test (jamais en prod)
SPLUNK_VERIFY_TLS=true

# --- Logging ---
LOG_LEVEL=INFO
